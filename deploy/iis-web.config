<?xml version="1.0" encoding="UTF-8"?>
<!--
    IIS Reverse Proxy Configuration
    ================================
    Place this web.config in your IIS site root folder.
    
    This routes all traffic from IIS (port 80/443) to the 
    Docker container running on port 8080.
    
    Prerequisites:
    - URL Rewrite Module installed
    - Application Request Routing (ARR) installed and proxy enabled
    - WebSocket Protocol enabled
-->
<configuration>
    <system.webServer>
        
        <!-- Enable WebSocket for Blazor SignalR -->
        <webSocket enabled="true" />
        
        <!-- URL Rewrite Rules -->
        <rewrite>
            <rules>
                <!-- Reverse Proxy to Docker Container -->
                <rule name="ReverseProxyToDocker" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions>
                        <add input="{CACHE_URL}" pattern="^(https?)://" />
                    </conditions>
                    <action type="Rewrite" url="http://localhost:8080/{R:1}" />
                    <serverVariables>
                        <set name="HTTP_X_FORWARDED_PROTO" value="{C:1}" />
                        <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
                        <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
                    </serverVariables>
                </rule>
            </rules>
            
            <outboundRules>
                <!-- Fix redirects from the app -->
                <rule name="RewriteResponseLocation" preCondition="IsRedirect">
                    <match serverVariable="RESPONSE_LOCATION" pattern="http://localhost:8080/(.*)" />
                    <action type="Rewrite" value="https://staging-terasupport-rdp.arcapps.org/{R:1}" />
                </rule>
                <preConditions>
                    <preCondition name="IsRedirect">
                        <add input="{RESPONSE_STATUS}" pattern="3\d\d" />
                    </preCondition>
                </preConditions>
            </outboundRules>
        </rewrite>
        
        <!-- Request filtering -->
        <security>
            <requestFiltering>
                <requestLimits maxAllowedContentLength="52428800" /> <!-- 50MB -->
            </requestFiltering>
        </security>

    </system.webServer>
</configuration>
