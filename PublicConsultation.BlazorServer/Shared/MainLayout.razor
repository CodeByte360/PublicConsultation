@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
            OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-3">Digital Public Consultation System</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Class="mr-4">Hello, @context.User.Identity?.Name</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Logout">Logout</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/login">Login</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Class="ml-2" Href="/register">Register
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <AuthorizeView>
                <Authorized>
                    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>

                    <AuthorizeView Roles="Admin" Context="adminContext">
                        <MudNavGroup Title="Admin" Icon="@Icons.Material.Filled.AdminPanelSettings">
                            <MudNavLink Href="/admin/dashboard" Match="NavLinkMatch.Prefix">Dashboard</MudNavLink>
                            <MudNavLink Href="/admin/users" Match="NavLinkMatch.Prefix">User Management</MudNavLink>
                        </MudNavGroup>
                    </AuthorizeView>

                    <AuthorizeView Roles="Admin,Official" Context="officialContext">
                        <MudNavGroup Title="Officer / Official" Icon="@Icons.Material.Filled.Work">
                            <MudNavLink Href="/admin/documents" Match="NavLinkMatch.Prefix">Draft Documents</MudNavLink>
                            <MudNavLink Href="/admin/opinions" Match="NavLinkMatch.Prefix">Public Feedback</MudNavLink>
                        </MudNavGroup>
                    </AuthorizeView>

                    <AuthorizeView Roles="Citizen" Context="citizenContext">
                        <MudDivider Class="my-2" />
                        <MudNavGroup Title="Citizen" Icon="@Icons.Material.Filled.People" Expanded="true">
                            <MudNavLink Href="/citizen/dashboard" Match="NavLinkMatch.Prefix">Dashboard</MudNavLink>
                            <MudNavLink Href="/active-consultations" Match="NavLinkMatch.Prefix">Public Consultations
                            </MudNavLink>
                        </MudNavGroup>
                    </AuthorizeView>
                </Authorized>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4 pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@inject NavigationManager NavigationManager
@inject PublicConsultation.Core.Interfaces.IAuthService AuthService

@code {
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void Logout()
    {
        NavigationManager.NavigateTo("/account/logout", forceLoad: true);
    }
}
