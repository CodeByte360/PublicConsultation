@page "/register"
@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@using PublicConsultation.Core.DTOs
@using PublicConsultation.BlazorServer.Pages.Components
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using System.IO
@using Microsoft.AspNetCore.Components.Forms
@inject IFileService FileService
@inject IAuthService AuthService
@inject IEmailService EmailService
@inject IOtpService OtpService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@using PublicConsultation.Core.Utilities

<MudContainer MaxWidth="MaxWidth.Medium" Class="d-flex align-center justify-center mud-width-full" Style="min-height: 90vh;">
    <MudCard Elevation="25" Class="pa-8 my-8" Style="width: 100%; border-radius: 12px;">
        <MudCardHeader Class="d-flex justify-center flex-column align-center">
            <CardHeaderContent>
                 <div class="d-flex justify-center mb-4">
                    <MudImage Src="images/Finallogo.png" Height="80" Alt="Logo" />
                </div>
                <MudText Typo="Typo.h5" Align="Align.Center" Style="font-weight: 700; color: var(--mud-palette-primary);">Create an Account</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">Join the Digital Public Consultation System</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudForm @ref="form" @bind-IsValid="@success" @bind-Errors="@errors">
                <MudGrid>
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-1"><strong>Account Credentials</strong></MudText>
                        <MudDivider Class="mb-4" />
                    </MudItem>
 
                    <MudItem xs="12" Class="d-flex flex-column align-center justify-center">
                         <MudAvatar Color="Color.Primary" Style="height:100px; width:100px; font-size:3rem;" Class="mb-2">
                            @if (!string.IsNullOrEmpty(registerModel.ProfilePictureUrl))
                            {
                                <MudImage Src="@registerModel.ProfilePictureUrl" Style="height:100%; width:100%; object-fit:cover;" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                            }
                        </MudAvatar>
                        <MudFileUpload T="IBrowserFile" OnFilesChanged="UploadFiles">
                            <ActivatorContent>
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                    StartIcon="@Icons.Material.Filled.CloudUpload">
                                    Upload Profile Picture
                                </MudButton>
                            </ActivatorContent>
                        </MudFileUpload>
                    </MudItem>


                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Email" Required="true" RequiredError="Email is required!"
                                      @bind-Value="registerModel.Email" InputType="InputType.Email" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email"
                                      Disabled="@isEmailVerified" />
                    </MudItem>
                    
                     <MudItem xs="12" sm="6" Class="d-flex align-center">
                         @if (!isEmailVerified)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="SendOtp" Disabled="@(string.IsNullOrEmpty(registerModel.Email) || isOtpSent)" Class="mr-2">
                                @(isOtpSent ? "OTP Sent" : "Send OTP")
                            </MudButton>
                        }
                        else
                        {
                             <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">Verified</MudChip>
                        }
                    </MudItem>

                     @if (isOtpSent && !isEmailVerified)
                    {
                        <MudItem xs="12" sm="6">
                            <MudTextField T="string" Label="Enter OTP" @bind-Value="otpInput" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6" Class="d-flex align-center">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="VerifyOtp">Verify OTP</MudButton>
                        </MudItem>
                    }

                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Password" Required="true" RequiredError="Password is required!"
                                      @bind-Value="registerModel.Password" InputType="@PasswordInput" Variant="Variant.Outlined" 
                                      Adornment="Adornment.End" AdornmentIcon="@PasswordInputIcon" OnAdornmentClick="TogglePasswordVisibility" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Confirm Password" Required="true"
                                      RequiredError="Password Confirmation is required!" @bind-Value="registerModel.ConfirmPassword"
                                      InputType="@PasswordInput" Validation="@(new Func<string, IEnumerable<string>>(PasswordMatch))" 
                                      Variant="Variant.Outlined" Adornment="Adornment.End" AdornmentIcon="@PasswordInputIcon" OnAdornmentClick="TogglePasswordVisibility" />
                    </MudItem>

                    <MudItem xs="12" Class="mt-4">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-1"><strong>Personal Information</strong></MudText>
                        <MudDivider Class="mb-4" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Full Name (English)" @bind-Value="registerModel.FullNameEnglish" Variant="Variant.Outlined" Required="true" RequiredError="Full Name (English) is required!"/>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Full Name (Bangla)" @bind-Value="registerModel.FullNameBangla" Variant="Variant.Outlined"/>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Mobile Number" @bind-Value="registerModel.PhoneNumber" Variant="Variant.Outlined" 
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Phone" Required="true" RequiredError="Mobile Number is required!"/>
                    </MudItem>
                     <MudItem xs="12" sm="6">
                        <MudTextField T="long" Label="NID Number" @bind-Value="registerModel.NIDNumber" Variant="Variant.Outlined" 
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge" Required="true" RequiredError="NID Number is required!"/>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Designation/Occupation" @bind-Value="registerModel.Designation" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Work"/>
                    </MudItem>

                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-1"><strong>Location Information</strong></MudText>
                        <MudDivider Class="mb-4" />
                        <LocationSelector PoliceStationId="registerModel.PoliceStationId" PoliceStationIdChanged="(val) => registerModel.PoliceStationId = val" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField T="string" Label="Present Address" @bind-Value="registerModel.Address" Variant="Variant.Outlined" 
                                      Lines="2" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Home"/>
                    </MudItem>

                    <MudItem xs="12" Class="d-flex justify-center mt-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Elevation="2" OnClick="Submit" Size="Size.Large"
                                   FullWidth="true" Disabled="@(!success || !isEmailVerified)" Class="py-2">Register</MudButton>
                    </MudItem>
                </MudGrid>
            </MudForm>
        </MudCardContent>
        <MudCardActions Class="d-flex justify-center pb-4">
             <MudText Typo="Typo.body2" Align="Align.Center">
                Already have an account? <MudLink Href="/login" Color="Color.Primary" Style="font-weight: 600;">Login here</MudLink>
            </MudText>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    MudForm form;
    bool success;
    string[] errors = { };

    RegisterRequest registerModel = new RegisterRequest();
    
    // OTP State
    bool isOtpSent = false;
    bool isEmailVerified = false;
    string otpInput = "";

    // Password visibility state
    bool isShowPassword = false;
    InputType PasswordInput = InputType.Password;
    string PasswordInputIcon = Icons.Material.Filled.VisibilityOff;

    void TogglePasswordVisibility()
    {
        isShowPassword = !isShowPassword;
        if (isShowPassword)
        {
            PasswordInputIcon = Icons.Material.Filled.Visibility;
            PasswordInput = InputType.Text;
        }
        else
        {
            PasswordInputIcon = Icons.Material.Filled.VisibilityOff;
            PasswordInput = InputType.Password;
        }
    }

    private IEnumerable<string> PasswordMatch(string arg)
    {
        if (registerModel.Password != arg)
            yield return "Passwords don't match";
    }

    private async Task UploadFiles(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            try
            {
                var maxFileSize = 5 * 1024 * 1024;
                using var stream = file.OpenReadStream(maxFileSize);
                var url = await FileService.UploadProfilePictureAsync(stream, file.Name);
                registerModel.ProfilePictureUrl = url;
                StateHasChanged();
                Snackbar.Add("Picture uploaded.", Severity.Info);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task SendOtp()
    {
        if (string.IsNullOrEmpty(registerModel.Email))
        {
            Snackbar.Add("Please enter an email address.", Severity.Warning);
            return;
        }
        
        // Simple regex check or let MudForm validate first? 
        // We'll trust the user to enter a valid-ish email for OTP
        
        try
        {
            var otp = await OtpService.GenerateOtpAsync(registerModel.Email);
            var emailBody = EmailTemplates.GetOtpEmail(otp, 5);
            await EmailService.SendEmailAsync(registerModel.Email, "Public Consultation - Email Verification", emailBody);
            
            isOtpSent = true;
            Snackbar.Add("OTP sent to your email.", Severity.Success);
        }
        catch (Exception ex)
        {
             Snackbar.Add($"Failed to send OTP: {ex.Message}", Severity.Error);
        }
    }

    private async Task VerifyOtp()
    {
        var isValid = await OtpService.ValidateOtpAsync(registerModel.Email, otpInput);
        if (isValid)
        {
            isEmailVerified = true;
            isOtpSent = false; // Hide OTP input
            Snackbar.Add("Email verified successfully!", Severity.Success);
        }
        else
        {
            Snackbar.Add("Invalid or expired OTP.", Severity.Error);
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid && isEmailVerified)
        {
            try
            {
                // Map DTO to Entity
                var user = new UserAccount
                {
                    Email = registerModel.Email,
                    FullNameEnglish = registerModel.FullNameEnglish,
                    FullNameBangla = registerModel.FullNameBangla,
                    PhoneNumber = registerModel.PhoneNumber,
                    NIDNumber = registerModel.NIDNumber,
                    Designation = registerModel.Designation,
                    Address = registerModel.Address,
                    PoliceStationId = registerModel.PoliceStationId,
                    ProfilePictureUrl = registerModel.ProfilePictureUrl,
                    IsVerified = false, // Email verified via OTP, but account verification is manual by Admin
                    IsActive = true
                };

                // In a real scenario you would verify uniqueness first or handle exception
                await AuthService.RegisterUserAsync(user, registerModel.Password);
                Snackbar.Add("Registration Successful!", Severity.Success);
                NavigationManager.NavigateTo("/login");
            }
            catch (Exception ex)
            {
                // Uniqueness violations will be caught here
                Snackbar.Add($"{ex.Message}", Severity.Error);
            }
        }
    }
}
