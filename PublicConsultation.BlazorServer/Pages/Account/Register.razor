@page "/register"
@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@using System.IO
@using Microsoft.AspNetCore.Components.Forms
@inject IFileService FileService
@inject IAuthService AuthService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Medium" Class="d-flex align-center justify-center mud-width-full" Style="min-height: 90vh;">
    <MudCard Elevation="25" Class="pa-8 my-8" Style="width: 100%; border-radius: 12px;">
        <MudCardHeader Class="d-flex justify-center flex-column align-center">
            <CardHeaderContent>
                 <div class="d-flex justify-center mb-4">
                    <MudImage Src="images/logo3.png" Height="80" Alt="Logo" />
                </div>
                <MudText Typo="Typo.h5" Align="Align.Center" Style="font-weight: 700; color: var(--mud-palette-primary);">Create an Account</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">Join the Digital Public Consultation System</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudForm @ref="form" @bind-IsValid="@success" @bind-Errors="@errors">
                <MudGrid>
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-1"><strong>Account Credentials</strong></MudText>
                        <MudDivider Class="mb-4" />
                    </MudItem>
 
                    <MudItem xs="12" Class="d-flex flex-column align-center justify-center">
                         <MudAvatar Color="Color.Primary" Style="height:100px; width:100px; font-size:3rem;" Class="mb-2">
                            @if (!string.IsNullOrEmpty(registerModel.ProfilePictureUrl))
                            {
                                <MudImage Src="@registerModel.ProfilePictureUrl" Style="height:100%; width:100%; object-fit:cover;" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                            }
                        </MudAvatar>
                        <MudFileUpload T="IBrowserFile" OnFilesChanged="UploadFiles">
                            <ActivatorContent>
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                    StartIcon="@Icons.Material.Filled.CloudUpload">
                                    Upload Profile Picture
                                </MudButton>
                            </ActivatorContent>
                        </MudFileUpload>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Username" Required="true" RequiredError="Username is required!"
                                      @bind-Value="registerModel.Username" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person"/>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Email" Required="true" RequiredError="Email is required!"
                                      @bind-Value="registerModel.Email" InputType="InputType.Email" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email"/>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Password" Required="true" RequiredError="Password is required!"
                                      @bind-Value="password" InputType="InputType.Password" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"/>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Confirm Password" Required="true"
                                      RequiredError="Password Confirmation is required!" @bind-Value="confirmPassword"
                                      InputType="InputType.Password" Validation="@(new Func<string, IEnumerable<string>>(PasswordMatch))" 
                                      Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.LockReset"/>
                    </MudItem>

                    <MudItem xs="12" Class="mt-4">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-1"><strong>Personal Information</strong></MudText>
                        <MudDivider Class="mb-4" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Full Name (English)" @bind-Value="registerModel.FullNameEnglish" Variant="Variant.Outlined"/>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Full Name (Bangla)" @bind-Value="registerModel.FullNameBangla" Variant="Variant.Outlined"/>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Mobile Number" @bind-Value="registerModel.PhoneNumber" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Phone"/>
                    </MudItem>
                     <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="NID Number" @bind-Value="registerModel.NIDNumber" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge"/>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Designation/Occupation" @bind-Value="registerModel.Designation" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Work"/>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Division" @bind-Value="registerModel.Division" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="District" @bind-Value="registerModel.District" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Address" @bind-Value="registerModel.Address" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Home" Lines="2"/>
                    </MudItem>
                    
                     <MudItem xs="12" Class="d-flex justify-center mt-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Elevation="2" OnClick="Submit" Size="Size.Large"
                                   FullWidth="true" Disabled="@(!success)" Class="py-2">Register</MudButton>
                    </MudItem>
                </MudGrid>
            </MudForm>
        </MudCardContent>
        <MudCardActions Class="d-flex justify-center pb-4">
             <MudText Typo="Typo.body2" Align="Align.Center">
                Already have an account? <MudLink Href="/login" Color="Color.Primary" Style="font-weight: 600;">Login here</MudLink>
            </MudText>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    MudForm form;
    bool success;
    string[] errors = { };

    UserAccount registerModel = new UserAccount();
    string password;
    string confirmPassword;

    private IEnumerable<string> PasswordMatch(string arg)
    {
        if (password != arg)
            yield return "Passwords don't match";
    }

    private async Task UploadFiles(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            try
            {
                var maxFileSize = 5 * 1024 * 1024;
                using var stream = file.OpenReadStream(maxFileSize);
                var url = await FileService.UploadProfilePictureAsync(stream, file.Name);
                registerModel.ProfilePictureUrl = url;
                StateHasChanged();
                Snackbar.Add("Picture uploaded.", Severity.Info);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid)
        {
            try
            {
                // In a real scenario you would verify uniqueness first or handle exception
                var user = await AuthService.RegisterUserAsync(registerModel, password);
                Snackbar.Add("Registration Successful!", Severity.Success);
                NavigationManager.NavigateTo("/login");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Registration Failed: {ex.Message}", Severity.Error);
            }
        }
    }
}
