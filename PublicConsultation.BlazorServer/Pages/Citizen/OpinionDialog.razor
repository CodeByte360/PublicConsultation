@using Microsoft.EntityFrameworkCore
@using PublicConsultation.Core.Entities
@using PublicConsultation.Infrastructure.Data
@using PublicConsultation.Core.Interfaces
@implements IDisposable
@inject ApplicationDbContext DbContext
@inject IDuplicateDetectionService DuplicateService
@inject IAuditLogService AuditLogService
@inject ISnackbar Snackbar
@inject IAiAnalysisService AiService
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.RateReview" Class="mr-3" Color="Color.Primary" />
            <div>
                <MudText Typo="Typo.h6">Submit Public Feedback</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Your feedback helps shape the legislative process
                    for <b>Rule @RuleNumber</b>.</MudText>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField Label="Detailed Opinion / Feedback" Value="model.OpinionText"
                        ValueChanged="@((string val) => OnTextChanged(val))" Lines="6" Required="true"
                        RequiredError="Opinion is required." Immediate="true" Variant="Variant.Outlined"
                        Placeholder="Tell us what you think about this provision..."
                        HelperText="Minimum 10 characters required for quality analysis." />
                </MudItem>

                @if (_isCheckingDuplicate)
                {
                    <MudItem xs="12" class="py-0">
                        <div class="d-flex align-center">
                            <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true"
                                Class="mr-2" />
                            <MudText Typo="Typo.caption">Checking for similar feedback...</MudText>
                        </div>
                    </MudItem>
                }

                @if (_isDuplicateDetected)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true"
                            Icon="@Icons.Material.Filled.Info" BorderClass="border-l-4">
                            Note: A similar opinion has already been submitted. Please Ensure your feedback provides unique
                            value.
                        </MudAlert>
                    </MudItem>
                }

                <MudItem xs="12">
                    <MudTextField @bind-Value="model.Suggestion" Label="Proposed Rewording / Improvement (Optional)"
                        Lines="3" Variant="Variant.Outlined"
                        Placeholder="Example: 'Instead of X, we should say Y because...'" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Class="px-6">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
            Disabled="@(!success || _isCheckingDuplicate)" StartIcon="@Icons.Material.Filled.Send" Class="px-8">
            Submit Feedback
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public Guid RuleId { get; set; }
    [Parameter] public string RuleNumber { get; set; } = string.Empty;
    [Parameter] public Guid UserId { get; set; }

    private MudForm form = null!;
    private bool success;
    private Opinion model = new Opinion();
    private bool _isDuplicateDetected = false;
    private bool _isCheckingDuplicate = false;
    private CancellationTokenSource? _cts;

    private async Task OnTextChanged(string val)
    {
        model.OpinionText = val;
        _isDuplicateDetected = false;

        if (string.IsNullOrWhiteSpace(val) || val.Length < 10) return;

        // Safe Debouncing using CancellationTokenSource
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        try
        {
            await Task.Delay(500, token);
            _isCheckingDuplicate = true;
            StateHasChanged();

            // Find similar opinions safely on the UI thread
            var similar = await DuplicateService.FindSimilarOpinionsAsync(val, RuleId);

            if (!token.IsCancellationRequested)
            {
                _isDuplicateDetected = similar.Any();
            }
        }
        catch (TaskCanceledException)
        {
            // Expected
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _isCheckingDuplicate = false;
                StateHasChanged();
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        _cts?.Cancel(); // Stop any pending duplicate checks
        await form.Validate();
        if (form.IsValid)
        {
            try
            {
                var rule = await DbContext.Rules.Include(r => r.DraftDocument).FirstOrDefaultAsync(r => r.Oid == RuleId);
                if (rule?.DraftDocument == null)
                {
                    Snackbar.Add("Error loading rule context.", Severity.Error);
                    return;
                }

                if (rule.DraftDocument.ConsultationEndDate < DateTime.Now)
                {
                    Snackbar.Add("This consultation has ended. Submissions are no longer accepted.", Severity.Error);
                    MudDialog.Cancel();
                    return;
                }

                model.RuleId = RuleId;
                model.UserId = UserId;
                model.CreatedDate = DateTime.UtcNow;

                // Analyze sentiment before saving
                model.Sentiment = await AiService.AnalyzeSentimentAsync(model.OpinionText);

                DbContext.Opinions.Add(model);
                await DbContext.SaveChangesAsync();

                // Log activity
                var httpContext = HttpContextAccessor.HttpContext;
                string ipAddress = httpContext?.Request.Headers["X-Forwarded-For"].FirstOrDefault() ??
                httpContext?.Connection?.RemoteIpAddress?.ToString() ?? "Unknown";

                // Map IPv6 loopback to IPv4 for better readability
                if (ipAddress == "::1") ipAddress = "127.0.0.1";

                var user = await DbContext.UserAccounts.FindAsync(UserId);
                await AuditLogService.LogActivityAsync(
                "Opinion Submitted",
                $"User {user?.FullNameEnglish ?? "Anonymous"} submitted an opinion for Rule {RuleNumber}",
                user?.Email ?? "Anonymous",
                ipAddress,
                null);

                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                // Silently handle logging errors or rethrow if DB fails
                Console.WriteLine($"Error during submission: {ex.Message}");
                MudDialog.Close(DialogResult.Ok(true)); // Still close as opinion was saved
            }
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
