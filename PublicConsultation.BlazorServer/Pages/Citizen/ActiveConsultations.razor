@page "/active-consultations"
@using PublicConsultation.Core.Entities
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true" Align="Align.Center">Active Public Consultations</MudText>
    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-8">Participate in the legislative process by giving
        your opinion on draft acts and rules.</MudText>

    @if (_loading)
    {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="d-block mx-auto" />
    }
    else if (!_documents.Any())
    {
            <MudAlert Severity="Severity.Info" Class="mt-4">No active consultations at the moment.</MudAlert>
    }
    else
    {
            <MudGrid>
            @foreach (var doc in _documents)
            {
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="4" Class="h-100 d-flex flex-column">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.h6">@doc.Title</MudText>
                                        <MudText Typo="Typo.caption">@doc.MinistryOrDepartment</MudText>
                                    </CardHeaderContent>
                                </MudCardHeader>
                                <MudCardContent Class="flex-grow-1">
                                    <MudText Typo="Typo.body2" Lines="3">@doc.Description</MudText>
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="mt-2">Open until
                                @doc.ConsultationEndDate.ToShortDateString()</MudChip>
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton Variant="Variant.Text" Color="Color.Primary"
                                        EndIcon="@Icons.Material.Filled.ArrowForward" Href="@($"/consultation/{doc.Oid}")">Participate
                                    </MudButton>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>
            }
            </MudGrid>
    }
</MudContainer>

@code {
    private List<DraftDocument> _documents = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _documents = await DbContext.DraftDocuments
        .Where(d => d.Status == "Published" && d.ConsultationEndDate >= DateTime.Today)
        .OrderByDescending(d => d.CreatedDate)
        .ToListAsync();
        _loading = false;
    }
}
