@page "/transparency/audit-log"
@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@inject IAuditLogService AuditLogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" Class="mb-6">Public Audit Log</MudText>
    <MudText Typo="Typo.body1" Class="mb-4">
        To ensure transparency and trust, all major activities regarding draft documents are recorded in this
        immutable-style audit log.
    </MudText>

    @inject IDialogService DialogService

    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudAlert Severity="(_isIntegrityVerified ? Severity.Success : Severity.Error)" Variant="Variant.Filled"
            Class="mb-6">
            @(_isIntegrityVerified
                ? "Structure Integrity Verified: All log hashes match the blockchain-lite chain."
                : "Warning: Log integrity could not be verified. Please contact system administration.")
        </MudAlert>

        <MudTable Items="@_logs" T="AuditLog" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="4">
            <HeaderContent>
                <MudTh>Timestamp</MudTh>
                <MudTh>Activity</MudTh>
                <MudTh>Document</MudTh>
                <MudTh>Details</MudTh>
                <MudTh>Action</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Timestamp">@context.CreatedDate.ToString("yyyy-MM-dd HH:mm:ss")</MudTd>
                <MudTd DataLabel="Activity">
                    <MudChip T="string" Color="Color.Info" Size="Size.Small">@context.Activity</MudChip>
                </MudTd>
                <MudTd DataLabel="Document">
                    @(context.RelatedDocument?.Title ?? "N/A")
                </MudTd>
                <MudTd DataLabel="Details">
                    <MudText Typo="Typo.body2"
                        Style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        @context.Details
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Action">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                        OnClick="@(() => OpenDetails(context))">View Details</MudButton>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    }
</MudContainer>

@code {
    private List<AuditLog> _logs = new();
    private bool _loading = true;
    private bool _isIntegrityVerified = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _logs = await AuditLogService.GetLogsAsync();
            _isIntegrityVerified = await AuditLogService.VerifyIntegrityAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading audit logs: {ex.Message}");
            Snackbar.Add("Error loading audit logs. Page failed to initialize correctly.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenDetails(AuditLog log)
    {
        var parameters = new DialogParameters { ["AuditLog"] = log };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        DialogService.Show<AuditLogDetailsDialog>("Audit Log Entry", parameters, options);
    }
}
