@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<MudPaper Elevation="0" Class="pa-4 d-flex flex-column align-center justify-center rounded-lg"
    Style="border: 1px dashed var(--mud-palette-primary); background-color: rgba(var(--mud-palette-primary-rgb), 0.05); min-height: 180px; transition: all 0.3s;">

    @if (string.IsNullOrEmpty(ImageData))
    {
        if (IsRegistered)
        {
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 4rem; opacity: 0.9;" />
            <MudText Typo="Typo.body2" Class="mt-2 mb-4" Align="Align.Center">@Label</MudText>
            <MudText Typo="Typo.caption" Color="Color.Success" Class="d-block mb-3"><b>Registered</b></MudText>
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Color="Color.Primary" Style="font-size: 4rem; opacity: 0.7;" />
            <MudText Typo="Typo.body2" Class="mt-2 mb-4" Align="Align.Center">@Label</MudText>
        }
    }
    else
    {
        <div style="position: relative;" class="mb-2">
            <MudImage Src="@($"data:image/png;base64,{ImageData}")"
                Style="height:100px; width:auto; border-radius: 4px; border: 1px solid #ddd;" />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                Variant="Variant.Filled" Style="position: absolute; top: -8px; right: -8px; z-index:5;"
                OnClick="ClearCapture" />
        </div>
        <MudText Typo="Typo.caption" Color="Color.Success" Class="d-block mb-3"><b>Captured</b></MudText>
    }

    <MudButton Variant="@(string.IsNullOrEmpty(ImageData) && !IsRegistered ? Variant.Filled : Variant.Outlined)"
        Color="Color.Primary" StartIcon="@Icons.Material.Filled.CropFree" OnClick="CaptureFingerprint"
        Disabled="@IsCapturing" Size="Size.Small" FullWidth="true" Class="mt-auto">
        @(IsCapturing ? "Scanning..." : (string.IsNullOrEmpty(ImageData) && !IsRegistered ? "SCAN" : "RE-SCAN"))
    </MudButton>

    @if (!string.IsNullOrEmpty(Error))
    {
        <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-2 text-center"
            Style="font-size: 0.7rem; line-height: 1.1;">@Error</MudText>
    }
</MudPaper>

@implements IDisposable

@code {
    [Parameter] public string Label { get; set; } = "Place finger on scanner";
    [Parameter] public EventCallback<FingerprintData> OnCaptured { get; set; }
    [Parameter] public string? ImageData { get; set; }
    [Parameter] public bool IsRegistered { get; set; }

    private string? Error { get; set; }
    private bool IsCapturing { get; set; }
    private bool _disposed;

    private async Task CaptureFingerprint()
    {
        if (_disposed) return;

        IsCapturing = true;
        Error = null;
        StateHasChanged();

        try
        {
            var result = await JSRuntime.InvokeAsync<SecuGenResult>("window.secugen.capture");

            if (_disposed) return;

            if (result.success)
            {
                ImageData = result.image;
                await OnCaptured.InvokeAsync(new FingerprintData { Image = result.image, Template = result.template });
                if (!_disposed) Snackbar.Add("Fingerprint captured successfully", Severity.Success);
            }
            else
            {
                Error = result.error;
                if (!_disposed) Snackbar.Add($"Capture failed: {result.error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            if (!_disposed)
            {
                Error = "Scanner not found. Is SecuGen WebAPI running?";
                Snackbar.Add(Error, Severity.Error);
            }
        }
        finally
        {
            if (!_disposed)
            {
                IsCapturing = false;
                StateHasChanged();
            }
        }
    }

    private async Task ClearCapture()
    {
        ImageData = null;
        await OnCaptured.InvokeAsync(new FingerprintData { Image = null, Template = null });
    }

    public void Dispose()
    {
        _disposed = true;
    }

    public class SecuGenResult
    {
        public bool success { get; set; }
        public string? image { get; set; }
        public string? template { get; set; }
        public string? error { get; set; }
    }

    public class FingerprintData
    {
        public string? Image { get; set; }
        public string? Template { get; set; }
    }
}
