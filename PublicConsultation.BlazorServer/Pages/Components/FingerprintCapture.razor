@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<MudPaper Elevation="0" Class="pa-4 border-2 border-dashed mud-border-primary"
    Style="text-align:center; min-height: 200px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
    @if (string.IsNullOrEmpty(ImageData))
    {
        <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Color="Color.Default" Style="font-size: 5rem;" />
        <MudText Typo="Typo.body2" Class="mt-2">@Label</MudText>
    }
    else
    {
        <div style="position: relative;">
            <MudImage Src="@($"data:image/png;base64,{ImageData}")"
                Style="height:120px; width:auto; border-radius: 4px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);" />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                Style="position: absolute; top: -10px; right: -10px; background: white;" OnClick="ClearCapture" />
        </div>
        <MudText Typo="Typo.caption" Color="Color.Success" Class="d-block mt-2"><b>Fingerprint Captured</b></MudText>
    }

    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CropFree"
        OnClick="CaptureFingerprint" Class="mt-4" FullWidth="true" Disabled="@IsCapturing">
        @(IsCapturing ? "Scanning..." : (string.IsNullOrEmpty(ImageData) ? "Capture" : "Re-capture"))
    </MudButton>

    @if (!string.IsNullOrEmpty(Error))
    {
        <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-2">@Error</MudText>
    }
</MudPaper>

@code {
    [Parameter] public string Label { get; set; } = "Place finger on scanner";
    [Parameter] public EventCallback<FingerprintData> OnCaptured { get; set; }
    [Parameter] public string? ImageData { get; set; }

    private string? Error { get; set; }
    private bool IsCapturing { get; set; }

    private async Task CaptureFingerprint()
    {
        IsCapturing = true;
        Error = null;
        StateHasChanged();

        try
        {
            var result = await JSRuntime.InvokeAsync<SecuGenResult>("window.secugen.capture");
            if (result.success)
            {
                ImageData = result.image;
                await OnCaptured.InvokeAsync(new FingerprintData { Image = result.image, Template = result.template });
                Snackbar.Add("Fingerprint captured successfully", Severity.Success);
            }
            else
            {
                Error = result.error;
                Snackbar.Add($"Capture failed: {result.error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Error = "Scanner not found. Is SecuGen WebAPI running?";
            Snackbar.Add(Error, Severity.Error);
        }
        finally
        {
            IsCapturing = false;
            StateHasChanged();
        }
    }

    private async Task ClearCapture()
    {
        ImageData = null;
        await OnCaptured.InvokeAsync(new FingerprintData { Image = null, Template = null });
    }

    public class SecuGenResult
    {
        public bool success { get; set; }
        public string? image { get; set; }
        public string? template { get; set; }
        public string? error { get; set; }
    }

    public class FingerprintData
    {
        public string? Image { get; set; }
        public string? Template { get; set; }
    }
}
