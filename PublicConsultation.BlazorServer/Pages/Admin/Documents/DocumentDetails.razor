@page "/admin/documents/{Id:guid}"
@attribute [Authorize(Roles = "Admin,Official")]
@using PublicConsultation.Core.Entities
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using PublicConsultation.Infrastructure.Services
@inject ApplicationDbContext DbContext
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject PublicConsultation.Core.Interfaces.IEmailService EmailService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    @if (_document == null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudPaper Class="pa-6 mb-6 shadow-sm border-l-8" Elevation="4"
            Style="border-left-color: var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-start">
                <div class="d-flex align-start">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Size="Size.Large"
                        Class="mr-4 mt-1" />
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight: 700;">@_document.Title</MudText>
                        <div class="d-flex align-center mt-1">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" Color="Color.Secondary"
                                Class="mr-2" />
                            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">@_document.MinistryOrDepartment</MudText>
                        </div>
                    </div>
                </div>
                <div class="d-flex flex-column align-end">
                    <div class="d-flex align-center mb-3">
                        <MudChip T="string" Color="@GetStatusColor(_document.Status)" Variant="Variant.Filled"
                            Size="Size.Small" Class="mr-2">Status: @_document.Status</MudChip>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">ID: @_document.Oid.ToString().Substring(0,8)...
                        </MudText>
                    </div>
                    <div class="d-flex">
                        @if (_document.Status == "Draft")
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="PublishDocument"
                                StartIcon="@Icons.Material.Filled.Public" Class="px-6 rounded-pill">Publish Consultation
                            </MudButton>
                        }
                        else if (_document.Status == "Published")
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="CloseConsultation"
                                StartIcon="@Icons.Material.Filled.Lock" Class="px-4 rounded-pill mr-2">Close</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.BarChart"
                                Class="px-4 rounded-pill" Href="@($"/admin/reports/comparative/{Id}")">View Analysis</MudButton>
                        }
                    </div>
                </div>
            </div>

            <MudDivider Class="my-4" />

            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudText Typo="Typo.body2" Style="line-height: 1.7; color: #444;">@_document.Description</MudText>
                </MudItem>
                <MudItem xs="12" md="4"
                    class="d-flex flex-column justify-center align-end border-l-2 pl-4 mud-border-lines-default">
                    <div class="d-flex align-center mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" Class="mr-2"
                            Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle2"><b>Consultation Timeline</b></MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                            Class="ml-2" OnClick="EditTimeline" Title="Edit Timeline" />
                    </div>
                    <MudText Typo="Typo.caption" Style="font-size: 0.9rem;">
                        @_document.ConsultationStartDate.ToString("MMM dd, yyyy") —
                        @_document.ConsultationEndDate.ToString("MMM dd, yyyy")
                    </MudText>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <div class="d-flex justify-space-between align-center mt-6 mb-2">
            <MudText Typo="Typo.h6">Rules & Provisions</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                OnClick="AddRule">Add Rule</MudButton>
        </div>

        <MudTable Items="@_rules" Hover="true" Dense="true" Elevation="2">
            <HeaderContent>
                <MudTh>Order</MudTh>
                <MudTh>Rule No</MudTh>
                <MudTh>Topic</MudTh>
                <MudTh>Existing</MudTh>
                <MudTh>Proposed</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Order">@context.DisplayOrder</MudTd>
                <MudTd DataLabel="Rule No">@context.RuleNumber</MudTd>
                <MudTd DataLabel="Topic">@context.SectionTitle</MudTd>
                <MudTd DataLabel="Existing">
                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@context.ExistingProvision</MudText>
                </MudTd>
                <MudTd DataLabel="Proposed">
                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@context.ProposedProvision</MudText>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info"
                        OnClick="@(() => EditRule(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                        OnClick="@(() => DeleteRule(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudContainer>

@code {
    [Parameter] public Guid Id { get; set; }
    private DraftDocument? _document;
    private List<Rule> _rules = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _document = await DbContext.DraftDocuments.FirstOrDefaultAsync(d => d.Oid == Id);
        if (_document != null)
        {
            _rules = await DbContext.Rules.Where(r => r.DraftDocumentId == Id).OrderBy(r => r.DisplayOrder).ToListAsync();
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Warning,
        "Published" => Color.Success,
        "Closed" => Color.Default,
        _ => Color.Info
    };

    private async Task PublishDocument()
    {
        if (_document != null)
        {
            _document.Status = "Published";
            await DbContext.SaveChangesAsync();
            await NotifyCitizensAsync(_document);
            Snackbar.Add("Document Published Successfully!", Severity.Success);
        }
    }

    private async Task NotifyCitizensAsync(DraftDocument doc)
    {
        var citizens = await DbContext.UserAccounts
        .Where(u => u.Role.Name == "Citizen" && u.IsActive)
        .Select(u => u.Email)
        .ToListAsync();

        if (citizens.Any())
        {
            var subject = $"New Public Consultation: {doc.Title}";
            var viewAllUrl = $"{NavigationManager.BaseUri}active-consultations";
            var viewDocUrl = $"{NavigationManager.BaseUri}consultation/{doc.Oid}";

            var body = EmailTemplateHelper.GetConsultationNotificationHtml(
            doc.Title,
            doc.MinistryOrDepartment,
            doc.Description ?? "",
            viewAllUrl,
            viewDocUrl);

            await EmailService.SendBulkEmailAsync(citizens, subject, body);
        }
    }

    private async Task CloseConsultation()
    {
        if (_document != null)
        {
            _document.Status = "Closed";
            await DbContext.SaveChangesAsync();
            Snackbar.Add("Consultation Closed.", Severity.Info);
        }
    }

    private async Task AddRule()
    {
        var parameters = new DialogParameters { ["DraftDocumentId"] = Id };
        var dialog = DialogService.Show<RuleDialog>("Add Rule", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task EditRule(Rule rule)
    {
        var parameters = new DialogParameters { ["RuleId"] = rule.Oid, ["DraftDocumentId"] = Id };
        var dialog = DialogService.Show<RuleDialog>("Edit Rule", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task EditTimeline()
    {
        var parameters = new DialogParameters { ["DocumentId"] = Id };
        var dialog = DialogService.Show<TimelineDialog>("Edit Timeline", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task DeleteRule(Rule rule)
    {
        bool? result = await DialogService.ShowMessageBox(
        "Warning",
        "Deleting can not be undone!",
        yesText: "Delete!", cancelText: "Cancel");

        if (result == true)
        {
            DbContext.Rules.Remove(rule);
            await DbContext.SaveChangesAsync();
            await LoadData();
            Snackbar.Add("Rule Deleted", Severity.Success);
        }
    }
}
