@page "/admin/documents"
@attribute [Authorize(Roles = "Admin,Official")]
@using PublicConsultation.Core.Entities
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject PublicConsultation.Core.Interfaces.IEmailService EmailService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h5">Draft Documents</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/documents/upload">Upload New Draft
        </MudButton>
    </div>

    <MudTable Items="@Documents" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading"
        LoadingProgressColor="Color.Info">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Ministry</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Consultation Period</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Ministry">@context.MinistryOrDepartment</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
            </MudTd>
            <MudTd DataLabel="Period">
                @context.ConsultationStartDate.ToShortDateString() - @context.ConsultationEndDate.ToShortDateString()
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                    Href="@($"/admin/documents/{context.Oid}")" Tooltip="Edit Details" />
                @if (context.Status == "Draft")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Publish" Color="Color.Success" Size="Size.Small"
                        OnClick="@(() => PublishQuick(context))" Tooltip="Quick Publish" />
                }
                @if (context.Status == "Published" || context.Status == "Closed")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Forum" Color="Color.Info" Size="Size.Small"
                        Href="@($"/admin/opinions/{context.Oid}")" Tooltip="View Opinions" />
                    <MudIconButton Icon="@Icons.Material.Filled.Assessment" Color="Color.Secondary" Size="Size.Small"
                        Href="@($"/admin/reports/comparative/{context.Oid}")" Tooltip="View Comparative Statement" />
                }
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                    Tooltip="Delete" />
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>

@code {
    private List<DraftDocument> Documents = new List<DraftDocument>();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        Documents = await DbContext.DraftDocuments.OrderByDescending(d => d.CreatedDate).ToListAsync();
        _loading = false;
    }

    private Color GetStatusColor(string status)
    {
        return status switch
        {
            "Draft" => Color.Warning,
            "Published" => Color.Success,
            "Closed" => Color.Default,
            _ => Color.Info
        };
    }

    private async Task PublishQuick(DraftDocument doc)
    {
        doc.Status = "Published";
        await DbContext.SaveChangesAsync();
        await NotifyCitizensAsync(doc);
        StateHasChanged();
    }

    private async Task NotifyCitizensAsync(DraftDocument doc)
    {
        var citizens = await DbContext.UserAccounts
        .Where(u => u.Role.Name == "Citizen")
        .Select(u => u.Email)
        .ToListAsync();

        if (citizens.Any())
        {
            var subject = $"New Public Consultation: {doc.Title}";
            var body = $@"
<h3>New Consultation Published</h3>
<p>The ministry has published a new draft document for public consultation: <strong>{doc.Title}</strong></p>
<p>Ministry: {doc.MinistryOrDepartment}</p>
<p>You can participate and give your opinion here:</p>
<p><a href='{NavigationManager.BaseUri}active-consultations'>View All Consultations</a></p>
<p>Or view this specific document directly:</p>
<p><a href='{NavigationManager.BaseUri}consultation/{doc.Oid}'>{doc.Title}</a></p>
<br/>
<p>Thank you for participating in the legislative process.</p>";

            await EmailService.SendBulkEmailAsync(citizens, subject, body);
        }
    }
}
