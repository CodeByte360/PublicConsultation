@using PublicConsultation.Core.Entities
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@(RuleId.HasValue ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add)" Class="mr-3" Color="Color.Primary" />
            <div>
                <MudText Typo="Typo.h6">@(RuleId.HasValue ? "Edit Rule / Provision" : "Add New Rule")</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Enter the details for this section of the public consultation document.</MudText>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success">
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudNumericField Label="Display Order" @bind-Value="model.DisplayOrder" 
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Min="1"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FormatListNumbered" />
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudTextField Label="Rule Number" @bind-Value="model.RuleNumber" Required="true" 
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="e.g., Section 1, Part A..." 
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Numbers" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Topic / Section Title" @bind-Value="model.SectionTitle" 
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Label" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Existing Provision (Current Law)" @bind-Value="model.ExistingProvision" 
                                  Lines="3" Variant="Variant.Outlined" HelperText="Leave empty if this is a new law." />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Proposed Provision (Modified Law)" @bind-Value="model.ProposedProvision" 
                                  Lines="4" Required="true" Variant="Variant.Outlined" 
                                  HelperText="Explain exactly how the language should change." />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Color="Color.Default" Class="px-6">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" 
                   Disabled="@(!success)" StartIcon="@Icons.Material.Filled.Save" Class="px-8">
            @(RuleId.HasValue ? "Update Changes" : "Save Rule")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public Guid DraftDocumentId { get; set; }
    [Parameter] public Guid? RuleId { get; set; }

    private MudForm form;
    private bool success;
    private Rule model = new Rule();

    protected override async Task OnInitializedAsync()
    {
        if (RuleId.HasValue)
        {
            var existing = await DbContext.Rules.FindAsync(RuleId.Value);
            if (existing != null)
            {
                // Simple clone to avoid tracking issues if we cancel
                model = new Rule
                    {
                        Oid = existing.Oid,
                        DraftDocumentId = existing.DraftDocumentId,
                        DisplayOrder = existing.DisplayOrder,
                        RuleNumber = existing.RuleNumber,
                        SectionTitle = existing.SectionTitle,
                        ExistingProvision = existing.ExistingProvision,
                        ProposedProvision = existing.ProposedProvision
                    };
            }
        }
        else
        {
            model.DraftDocumentId = DraftDocumentId;
            // Auto increment order
            var maxOrder = await DbContext.Rules
            .Where(r => r.DraftDocumentId == DraftDocumentId)
            .MaxAsync(r => (int?)r.DisplayOrder) ?? 0;
            model.DisplayOrder = maxOrder + 1;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid)
        {
            if (RuleId.HasValue)
            {
                // Update
                var existing = await DbContext.Rules.FindAsync(RuleId.Value);
                if (existing != null)
                {
                    existing.DisplayOrder = model.DisplayOrder;
                    existing.RuleNumber = model.RuleNumber;
                    existing.SectionTitle = model.SectionTitle;
                    existing.ExistingProvision = model.ExistingProvision;
                    existing.ProposedProvision = model.ProposedProvision;
                    DbContext.Rules.Update(existing);
                }
            }
            else
            {
                // Create
                DbContext.Rules.Add(model);
            }

            await DbContext.SaveChangesAsync();
            Snackbar.Add("Rule Saved", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }
}
