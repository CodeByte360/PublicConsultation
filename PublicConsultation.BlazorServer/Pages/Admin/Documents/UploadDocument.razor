@page "/admin/documents/upload"
@attribute [Authorize(Roles = "Admin")]
@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@using PublicConsultation.Infrastructure.Data
@inject IDocumentService DocumentService
@inject IMinistryService MinistryService
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Class="pa-8 pb-10 shadow-lg" Elevation="4">
        <div class="d-flex align-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.FileUpload" Color="Color.Primary" Size="Size.Large" Class="mr-3" />
            <div>
                <MudText Typo="Typo.h5" Style="font-weight: 700;">Initiate Public Consultation</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Upload a new draft document to begin the public review and amendment process.</MudText>
            </div>
        </div>

        <MudDivider Class="mb-8" />

        <MudForm @ref="form" @bind-IsValid="@success">
            <MudGrid Spacing="4">
                <MudItem xs="12">
                    <MudTextField T="string" Label="Document Title / Legislative Act Name" Required="true" 
                                  @bind-Value="model.Title" Variant="Variant.Outlined" 
                                  Placeholder="e.g. Cyber Security Act, 2026 (Draft)"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Title" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid?" Label="Originating Ministry" Required="true" @bind-Value="model.MinistryId"
                               Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter"
                               Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountBalance">
                        @foreach (var ministry in Ministries)
                        {
                            <MudSelectItem Value="@((Guid?)ministry.Oid)">@ministry.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudDateRangePicker Label="Consultation Timeline" @bind-DateRange="_dateRange" Required="true"
                                        Variant="Variant.Outlined" PickerVariant="PickerVariant.Dialog" 
                                        Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.DateRange"
                                        HelperText="Select start and end dates for submissions." />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField T="string" Label="Description & Objectives" Lines="4" @bind-Value="model.Description" 
                                  Variant="Variant.Outlined" Placeholder="Briefly explain the purpose of this consultation..."
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Notes" />
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Class="pa-6 d-flex flex-column align-center border-dashed border-2 mud-border-primary" 
                              Elevation="0" Style="background-color: #f8f9fa;">
                        <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                        <MudText Typography="Typo.subtitle1" Class="mb-1"><b>Document Attachment</b></MudText>
                        <MudText Typography="Typo.caption" Class="mb-4 text-center">Supported formats: PDF, DOCX (Max 10MB). <br/> Our AI will automatically parse rules and sections from the file.</MudText>
                        
                        <MudFileUpload T="IBrowserFile" OnFilesChanged="UploadFile">
                            <ActivatorContent>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.CloudUpload" Class="px-8 rounded-pill">
                                    @( _file == null ? "Select Document" : "Change Document")
                                </MudButton>
                            </ActivatorContent>
                        </MudFileUpload>

                        @if (_file != null)
                        {
                            <MudAlert Severity="Severity.Success" Variant="Variant.Text" Class="mt-4 py-1" Dense="true" Icon="@Icons.Material.Filled.CheckCircle">
                                Ready: @_file.Name (@((_file.Size / 1024).ToString("N0")) KB)
                            </MudAlert>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" class="d-flex justify-end mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Submit" 
                               Size="Size.Large" Class="px-12 rounded-pill shadow-lg"
                               StartIcon="@Icons.Material.Filled.Send" Style="min-width: 250px;">
                        Upload & Parse Rules
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    MudForm form;
    bool success;
    DraftDocument model = new DraftDocument();
    DateRange _dateRange = new DateRange(DateTime.Today, DateTime.Today.AddDays(14));
    IBrowserFile _file;
    List<Ministry> Ministries = new();

    protected override async Task OnInitializedAsync()
    {
        Ministries = await MinistryService.GetAllMinistriesAsync();
    }

    private void UploadFile(InputFileChangeEventArgs e)
    {
        _file = e.File;
    }

    private async Task Submit()
    {
        await form.Validate();

        if (_file == null)
        {
            Snackbar.Add("Please select a document file.", Severity.Error);
            return;
        }

        if (form.IsValid)
        {
            try
            {
                // Upload File
                using var stream = _file.OpenReadStream(10 * 1024 * 1024); // 10MB limit
                var filePath = await DocumentService.UploadDocumentAsync(stream, _file.Name);

                // Save Entity
                model.FilePath = filePath;
                model.ConsultationStartDate = _dateRange.Start ?? DateTime.Today;
                model.ConsultationEndDate = _dateRange.End ?? DateTime.Today.AddDays(14);
                model.Status = "Draft";

                // Set deprecated field for compatibility if needed, or leave empty
                model.MinistryOrDepartment = Ministries.FirstOrDefault(m => m.Oid == model.MinistryId)?.Name ?? string.Empty;

                DbContext.DraftDocuments.Add(model);
                await DbContext.SaveChangesAsync();

                // Trigger Parsing (Fire and forget or await?) - For now await
                var rules = await DocumentService.ParseDocumentAsync(filePath);
                foreach (var rule in rules)
                {
                    rule.DraftDocumentId = model.Oid;
                    DbContext.Rules.Add(rule);
                }
                await DbContext.SaveChangesAsync();

                Snackbar.Add("Document uploaded and parsed successfully!", Severity.Success);
                NavigationManager.NavigateTo("/admin/documents");
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}
