@page "/admin/opinions"
@page "/admin/opinions/{DocumentId:guid}"
@attribute [Authorize(Roles = "Admin,Official")]
@using PublicConsultation.Core.Entities
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject PublicConsultation.Core.Interfaces.IAiAnalysisService AiService
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudText Typo="Typo.h4" Class="mb-6">Public Feedback & Opinions</MudText>

    <MudPaper Class="pa-4 mb-6">
        <MudGrid>
            <MudItem xs="12" md="5">
                <MudSelect T="Guid?" Label="Filter by Document" Value="@DocumentId" ValueChanged="OnDocumentChanged"
                    Clearable="true">
                    <MudSelectItem T="Guid?" Value="null">All Documents</MudSelectItem>
                    @foreach (var doc in _documents)
                    {
                        <MudSelectItem T="Guid?" Value="@doc.Oid">@doc.Title</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="5" Class="d-flex align-end">
                <MudTextField @bind-Value="_searchString" Placeholder="Search feedback text..."
                    Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                    Class="mt-0" Clearable="true" />
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-end justify-end">
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="ReanalyzeAll"
                    Disabled="@_isAnalyzing"
                    StartIcon="@(_isAnalyzing ? Icons.Material.Filled.Loop : Icons.Material.Filled.Refresh)">
                    @(_isAnalyzing ? "Analyzing..." : "Re-Run AI")
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudGrid Class="mb-6">
        <MudItem xs="12" md="4">
            <MudAlert Severity="@GetAggregateSeverity()" Variant="Variant.Filled"
                ContentAlignment="HorizontalAlignment.Center"
                Class="py-6 d-flex flex-column align-center justify-center" Style="height: 100%;">
                <MudText Typo="Typo.h6">Overall Sentiment</MudText>
                <MudText Typo="Typo.h4"><b>@GetAggregateSentiment()</b></MudText>
            </MudAlert>
        </MudItem>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4 d-flex align-center justify-space-between" Style="height: 100%;">
                <div style="width: 280px;" class="d-flex justify-center">
                    <MudChart ChartType="ChartType.Donut" Width="200px" Height="200px" InputData="@GetChartData()"
                        InputLabels="@_chartLabels" ChartOptions="@_chartOptions">
                        <CustomGraphics>
                            <text class="donut-inner-text" x="50%" y="45%" dominant-baseline="middle"
                                text-anchor="middle" fill="black" font-family="Helvetica" font-size="2">Total</text>
                            <text class="donut-inner-text" x="50%" y="58%" dominant-baseline="middle"
                                text-anchor="middle" fill="black" font-family="Helvetica"
                                font-size="5">@_filteredOpinions.Count()</text>
                        </CustomGraphics>
                    </MudChart>
                </div>
                <div class="d-flex flex-column justify-center flex-grow-1 ml-6 mr-4">
                    <div class="d-flex align-center justify-space-between mb-2">
                        <div class="d-flex align-center">
                            <div
                                style="width:12px; height:12px; background:#00c853; border-radius:50%; margin-right:8px;">
                            </div>
                            <MudText>Positive</MudText>
                        </div>
                        <MudText Typo="Typo.h6"><b>@CountSentiment("Positive")</b></MudText>
                    </div>
                    <div class="d-flex align-center justify-space-between mb-2">
                        <div class="d-flex align-center">
                            <div
                                style="width:12px; height:12px; background:#f44336; border-radius:50%; margin-right:8px;">
                            </div>
                            <MudText>Negative</MudText>
                        </div>
                        <MudText Typo="Typo.h6"><b>@CountSentiment("Negative")</b></MudText>
                    </div>
                    <div class="d-flex align-center justify-space-between mb-2">
                        <div class="d-flex align-center">
                            <div
                                style="width:12px; height:12px; background:#ff9800; border-radius:50%; margin-right:8px;">
                            </div>
                            <MudText>Mixed</MudText>
                        </div>
                        <MudText Typo="Typo.h6"><b>@CountSentiment("Mixed")</b></MudText>
                    </div>
                    <div class="d-flex align-center justify-space-between">
                        <div class="d-flex align-center">
                            <div
                                style="width:12px; height:12px; background:#e0e0e0; border-radius:50%; margin-right:8px;">
                            </div>
                            <MudText>Neutral</MudText>
                        </div>
                        <MudText Typo="Typo.h6"><b>@CountSentiment("Neutral")</b></MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudTable Items="@_filteredOpinions" Hover="true" Bordered="true" Striped="true" Loading="@_loading" Elevation="4">
        <HeaderContent>
            <MudTh>Date</MudTh>
            <MudTh>Citizen</MudTh>
            <MudTh>Document / Section</MudTh>
            <MudTh>Opinion</MudTh>
            <MudTh>Sentiment (AI)</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Date">@context.CreatedDate.ToShortDateString()</MudTd>
            <MudTd DataLabel="Citizen">
                <div class="d-flex align-center">
                    <b>@context.User?.FullNameEnglish</b>
                    @if (context.User?.IsVerified == true)
                    {
                        <MudTooltip Text="Verified Citizen">
                            <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Info" Size="Size.Small"
                                Class="ml-1" />
                        </MudTooltip>
                    }
                </div>
                <MudText Typo="Typo.caption">@context.User?.Email</MudText>
            </MudTd>
            <MudTd DataLabel="Section">
                <MudLink Href="@($"/consultation/{context.Rule?.DraftDocumentId}")" Typo="Typo.body2">
                    @context.Rule?.DraftDocument?.Title
                </MudLink><br />
                <MudText Typo="Typo.caption">Section @context.Rule?.RuleNumber: @context.Rule?.SectionTitle</MudText>
            </MudTd>
            <MudTd DataLabel="Opinion">
                <MudText Typo="Typo.body2">@context.OpinionText</MudText>
                @if (!string.IsNullOrEmpty(context.Summary))
                {
                    <MudText Typo="Typo.caption" Color="Color.Primary" Class="d-block mt-1">
                        <b>AI Summary:</b> @context.Summary
                    </MudText>
                }
                @if (!string.IsNullOrEmpty(context.Suggestion))
                {
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mt-1 py-0 px-2" NoIcon="true">
                        <MudText Typo="Typo.caption"><b>Suggestion:</b> @context.Suggestion</MudText>
                    </MudAlert>
                }
            </MudTd>
            <MudTd DataLabel="Sentiment">
                <MudChip T="string" Color="@GetSentimentColor(context.Sentiment)" Size="Size.Small">@(context.Sentiment
                    ?? "Pending")</MudChip>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.BarChart" Color="Color.Primary" Size="Size.Small"
                        Href="@($"/admin/reports/comparative/{context.Rule?.DraftDocumentId}")" Tooltip="View Report" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudContainer>

    @code {
    [Parameter] public Guid? DocumentId { get; set; }

    private List<Opinion> _opinions = new();
    private List<DraftDocument> _documents = new();
    private string _searchString = "";
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _documents = await DbContext.DraftDocuments.OrderByDescending(d => d.CreatedDate).ToListAsync();
        await LoadOpinions();
        _loading = false;
    }

    private async Task LoadOpinions()
    {
        var query = DbContext.Opinions
        .Include(o => o.User)
        .Include(o => o.Rule)
        .ThenInclude(r => r!.DraftDocument)
        .AsQueryable();

        if (DocumentId.HasValue)
        {
            query = query.Where(o => o.Rule!.DraftDocumentId == DocumentId.Value);
        }

        _opinions = await query.OrderByDescending(o => o.CreatedDate).ToListAsync();

        // Backfill sentiment and summary for opinions that lack it
        bool needsSave = false;
        foreach (var op in _opinions)
        {
            bool updated = false;
            if (string.IsNullOrEmpty(op.Sentiment) || op.Sentiment == "Neutral")
            {
                op.Sentiment = await AiService.AnalyzeSentimentAsync(op.OpinionText);
                updated = true;
            }
            if (string.IsNullOrEmpty(op.Summary))
            {
                op.Summary = await AiService.SummarizeOpinionAsync(op.OpinionText);
                updated = true;
            }
            if (updated) needsSave = true;
        }
        if (needsSave)
        {
            await DbContext.SaveChangesAsync();
        }
    }

    private IEnumerable<Opinion> _filteredOpinions => _opinions
    .Where(o => string.IsNullOrWhiteSpace(_searchString) ||
    o.OpinionText.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
    (o.User?.FullNameEnglish?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false));

    private void OnDocumentChanged(Guid? id)
    {
        DocumentId = id;
        NavigationManager.NavigateTo(id.HasValue ? $"/admin/opinions/{id}" : "/admin/opinions");
        Task.Run(LoadOpinions).ContinueWith(_ => InvokeAsync(StateHasChanged));
    }

    private Color GetSentimentColor(string? s)
    {
        if (string.IsNullOrEmpty(s)) return Color.Default;
        if (s.StartsWith("Positive")) return Color.Success;
        if (s.StartsWith("Negative")) return Color.Error;
        if (s.StartsWith("Mixed")) return Color.Warning;
        return Color.Default;
    }

    private string GetAggregateSentiment()
    {
        if (!_filteredOpinions.Any()) return "No Data";
        var pos = _filteredOpinions.Count(o => (o.Sentiment ?? "").StartsWith("Positive"));
        var neg = _filteredOpinions.Count(o => (o.Sentiment ?? "").StartsWith("Negative"));
        if (pos > neg * 1.5) return "Mostly Positive";
        if (neg > pos * 1.5) return "Highly Critical";
        if (pos > 0 && neg > 0) return "Mixed Feedback";
        return "Neutral / Balanced";
    }

    private Severity GetAggregateSeverity() => GetAggregateSentiment() switch
    {
        "Mostly Positive" => Severity.Success,
        "Highly Critical" => Severity.Error,
        "Mixed Feedback" => Severity.Warning,
        _ => Severity.Normal
    };

    private string[] _chartLabels = { "Positive", "Negative", "Mixed", "Neutral" };
    private ChartOptions _chartOptions = new ChartOptions
        {
            ChartPalette = new[] { "#00c853", "#f44336", "#ff9800", "#bdbdbd" }
        };

    private double[] GetChartData()
    {
        return new double[] {
CountSentiment("Positive"),
CountSentiment("Negative"),
CountSentiment("Mixed"),
CountSentiment("Neutral")
};
    }

    private int CountSentiment(string type)
    {
        if (type == "Neutral")
            return _filteredOpinions.Count(o => string.IsNullOrEmpty(o.Sentiment) || o.Sentiment.StartsWith("Neutral"));

        return _filteredOpinions.Count(o => (o.Sentiment ?? "").StartsWith(type));
    }

    private bool _isAnalyzing = false;
    [Inject] ISnackbar Snackbar { get; set; } = null!;

    private async Task ReanalyzeAll()
    {
        if (_filteredOpinions == null || !_filteredOpinions.Any()) return;

        _isAnalyzing = true;
        int count = 0;
        foreach (var op in _filteredOpinions.ToList())
        {
            op.Sentiment = await AiService.AnalyzeSentimentAsync(op.OpinionText);
            op.Summary = await AiService.SummarizeOpinionAsync(op.OpinionText);
            count++;
            StateHasChanged(); // Animate progress
            await Task.Delay(50); // Small delay to not freeze UI
        }
        await DbContext.SaveChangesAsync();
        _isAnalyzing = false;
        Snackbar.Add($"Verified/Updated sentiment for {count} opinions.", Severity.Success);
    }
}
