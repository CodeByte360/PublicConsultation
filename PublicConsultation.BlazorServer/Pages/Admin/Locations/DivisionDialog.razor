@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@inject ILocationService LocationService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(Model.Oid == Guid.Empty ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)"
                Class="mr-3 mb-n1" />
            @(Model.Oid == Guid.Empty ? "Add New Division" : "Edit Division")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success">
            <MudTextField Label="Division Name" @bind-Value="Model.Name" Required="true"
                RequiredError="Division name is required!" Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!success)">Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public Division Model { get; set; } = new Division();

    MudForm form;
    bool success;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid)
        {
            bool result;
            if (Model.Oid == Guid.Empty)
            {
                Model.Oid = Guid.NewGuid();
                result = await LocationService.SaveDivisionAsync(Model);
            }
            else
            {
                result = await LocationService.UpdateDivisionAsync(Model);
            }

            if (result)
            {
                Snackbar.Add("Division saved successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Error saving division", Severity.Error);
            }
        }
    }
}
