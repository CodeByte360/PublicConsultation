@page "/admin/locations/divisions"
@attribute [Authorize(Roles = "Admin")]
@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@inject ILocationService LocationService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h5">Divisions</MudText>
            <MudBreadcrumbs Items="_breadcrumbs" />
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
            OnClick="OpenCreateDialog">Add Division</MudButton>
    </div>

    <MudTable Items="@_divisions" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading" Elevation="25"
        Class="rounded-lg">
        <HeaderContent>
            <MudTh>Oid</MudTh>
            <MudTh>Name</MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Oid">@context.Oid</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Actions" Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info"
                    OnClick="@(() => OpenEditDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                    OnClick="@(() => DeleteDivision(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No divisions found.</MudText>
        </NoRecordsContent>
    </MudTable>
</MudContainer>

@code {
    private IEnumerable<Division> _divisions = new List<Division>();
    private bool _loading = true;
    private List<BreadcrumbItem> _breadcrumbs = new List<BreadcrumbItem>
{
new BreadcrumbItem("Dashboard", href: "/admin/dashboard"),
new BreadcrumbItem("Locations", href: null, disabled: true),
new BreadcrumbItem("Divisions", href: null, disabled: true)
};

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _divisions = await LocationService.GetDivisionsAsync();
        _loading = false;
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<DivisionDialog>("Add New Division", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task OpenEditDialog(Division division)
    {
        var parameters = new DialogParameters { ["Model"] = new Division { Oid = division.Oid, Name = division.Name } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<DivisionDialog>("Edit Division", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task DeleteDivision(Division division)
    {
        bool? confirm = await DialogService.ShowMessageBox(
        "Delete Division",
        $"Are you sure you want to delete {division.Name}? This may affect linked districts.",
        yesText: "Delete", cancelText: "Cancel");

        if (confirm == true)
        {
            var success = await LocationService.DeleteDivisionAsync(division.Oid);
            if (success)
            {
                Snackbar.Add("Division deleted successfully", Severity.Success);
                await LoadData();
            }
            else
            {
                Snackbar.Add("Failed to delete division. It might have linked districts.", Severity.Error);
            }
        }
    }
}
