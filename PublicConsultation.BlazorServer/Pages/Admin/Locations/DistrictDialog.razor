@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@inject ILocationService LocationService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(Model.Oid == Guid.Empty ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)"
                Class="mr-3 mb-n1" />
            @(Model.Oid == Guid.Empty ? "Add New District" : "Edit District")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success">
            <MudSelect T="Guid" Label="Select Division" @bind-Value="Model.DivisionId" Required="true"
                Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4">
                @foreach (var div in _divisions)
                {
                    <MudSelectItem Value="@div.Oid">@div.Name</MudSelectItem>
                }
            </MudSelect>
            <MudTextField Label="District Name" @bind-Value="Model.Name" Required="true"
                RequiredError="District name is required!" Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!success)">Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public District Model { get; set; } = new District();

    private IEnumerable<Division> _divisions = new List<Division>();
    MudForm form;
    bool success;

    protected override async Task OnInitializedAsync()
    {
        _divisions = await LocationService.GetDivisionsAsync();
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid)
        {
            bool result;
            if (Model.Oid == Guid.Empty)
            {
                Model.Oid = Guid.NewGuid();
                result = await LocationService.SaveDistrictAsync(Model);
            }
            else
            {
                result = await LocationService.UpdateDistrictAsync(Model);
            }

            if (result)
            {
                Snackbar.Add("District saved successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Error saving district", Severity.Error);
            }
        }
    }
}
