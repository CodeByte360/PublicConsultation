@page "/admin/dashboard"
@attribute [Authorize(Roles = "Admin")]
@using PublicConsultation.Core.Entities
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Admin Dashboard</MudText>

    <MudGrid>
        @* Summary Cards *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 d-flex flex-column align-center justify-center mud-width-full" Elevation="4"
                Style="height:120px; background-color: #594AE2; color: white;">
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.h6">@_totalUsers Citizens</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 d-flex flex-column align-center justify-center mud-width-full" Elevation="4"
                Style="height:120px; background-color: #FF7043; color: white;">
                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.h6">@_totalDocs Documents</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 d-flex flex-column align-center justify-center mud-width-full" Elevation="4"
                Style="height:120px; background-color: #26A69A; color: white;">
                <MudIcon Icon="@Icons.Material.Filled.Comment" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.h6">@_totalOpinions Opinions</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 d-flex flex-column align-center justify-center mud-width-full" Elevation="4"
                Style="height:120px; background-color: #EC407A; color: white;">
                <MudIcon Icon="@Icons.Material.Filled.PublishedWithChanges" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.h6">@_activeConsultations Active</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.h5" Class="mb-4">Advanced Analytics</MudText>
        </MudItem>

        @* Row 1: Status and Sentiment *@
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 400px;">
                <MudText Typo="Typo.h6" Class="mb-4">Document Status</MudText>
                <div class="d-flex justify-center">
                    <MudChart ChartType="ChartType.Donut" InputData="@_docStatusData" InputLabels="@_docStatusLabels"
                        Width="180px" Height="180px" />
                </div>
                <div class="mt-4">
                    <div class="d-flex justify-space-between mb-2">
                        <MudText Typo="Typo.body2">Draft</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@_draftCount</MudChip>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Published</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">@_publishedCount</MudChip>
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 400px;">
                <MudText Typo="Typo.h6" Class="mb-4">Public Sentiment</MudText>
                <div class="d-flex justify-center">
                    <MudChart ChartType="ChartType.Donut" InputData="@_sentimentData" InputLabels="@_sentimentLabels"
                        Width="180px" Height="180px" 
                        ChartOptions="@(new ChartOptions { ChartPalette = new string[] { "#4CAF50", "#F44336", "#FFC107", "#9E9E9E" } })" />
                </div>
                <div class="mt-8">
                    <div class="d-flex justify-space-between mb-1">
                        <MudText Typo="Typo.body2" Color="Color.Success">Positive</MudText>
                        <MudText Typo="Typo.body2"><strong>@_sentimentData[0]</strong></MudText>
                    </div>
                    <div class="d-flex justify-space-between mb-1">
                        <MudText Typo="Typo.body2" Color="Color.Error">Negative</MudText>
                        <MudText Typo="Typo.body2"><strong>@_sentimentData[1]</strong></MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 400px; overflow-y: auto;">
                <MudText Typo="Typo.h6" Class="mb-4">Recent Opinions</MudText>
                <MudList T="string" Dense="true">
                    @foreach (var op in _recentOpinions)
                    {
                        <MudListItem>
                            <div class="d-flex flex-column">
                                <MudText Typo="Typo.body2"><b>@op.User?.FullNameEnglish</b></MudText>
                                <MudText Typo="Typo.caption" Class="text-truncate">@op.OpinionText</MudText>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>

        @* Row 2: Heatmap *@
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4">Controversial Sections (Heatmap)</MudText>
                <MudTable Items="@_controversialSections" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                    <HeaderContent>
                        <MudTh>Section</MudTh>
                        <MudTh>Total Feedback</MudTh>
                        <MudTh>Negative Opinions</MudTh>
                        <MudTh>Controversy Level</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Section">
                            <MudText Typo="Typo.body2"><strong>@context.SectionTitle</strong></MudText>
                            <MudText Typo="Typo.caption">@context.DocTitle</MudText>
                        </MudTd>
                        <MudTd DataLabel="Total">@context.TotalFeedback</MudTd>
                        <MudTd DataLabel="Negative">
                            <MudText Color="Color.Error"><b>@context.NegativeCount</b></MudText>
                        </MudTd>
                        <MudTd DataLabel="Sentiment">
                             <MudProgressLinear Color="@(GetHeatmapColor(context.NegativeRatio))" Value="@(context.NegativeRatio * 100)" Class="my-7" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private int _totalUsers;
    private int _totalDocs;
    private int _totalOpinions;
    private int _activeConsultations;
    private int _draftCount;
    private int _publishedCount;

    private List<Opinion> _recentOpinions = new();
    private double[] _docStatusData = new double[2];
    private string[] _docStatusLabels = { "Draft", "Published" };

    private double[] _sentimentData = new double[4];
    private string[] _sentimentLabels = { "Positive", "Negative", "Mixed", "Neutral" };
    private List<ControversialSection> _controversialSections = new();

    protected override async Task OnInitializedAsync()
    {
        _totalUsers = await DbContext.UserAccounts.CountAsync(u => u.Role.Name == "Citizen");
        _totalDocs = await DbContext.DraftDocuments.CountAsync();
        _totalOpinions = await DbContext.Opinions.CountAsync();
        _activeConsultations = await DbContext.DraftDocuments.CountAsync(d => d.Status == "Published");

        _draftCount = await DbContext.DraftDocuments.CountAsync(d => d.Status == "Draft");
        _publishedCount = await DbContext.DraftDocuments.CountAsync(d => d.Status == "Published");
        _docStatusData = new double[] { _draftCount, _publishedCount };

        // Calculate Global Sentiment
        var allOpinions = await DbContext.Opinions.ToListAsync();
        _sentimentData[0] = allOpinions.Count(o => o.Sentiment == "Positive");
        _sentimentData[1] = allOpinions.Count(o => o.Sentiment == "Negative");
        _sentimentData[2] = allOpinions.Count(o => o.Sentiment == "Mixed");
        _sentimentData[3] = allOpinions.Count(o => string.IsNullOrEmpty(o.Sentiment) || o.Sentiment == "Neutral");

        // Calculate Controversial Sections
        _controversialSections = await DbContext.Opinions
            .Include(o => o.Rule)
            .ThenInclude(r => r.DraftDocument)
            .GroupBy(o => o.RuleId)
            .Select(g => new ControversialSection
            {
                SectionTitle = g.First().Rule.SectionTitle,
                DocTitle = g.First().Rule.DraftDocument.Title,
                TotalFeedback = g.Count(),
                NegativeCount = g.Count(o => o.Sentiment == "Negative")
            })
            .OrderByDescending(s => s.NegativeCount)
            .Take(5)
            .ToListAsync();

        _recentOpinions = await DbContext.Opinions
            .Include(o => o.User)
            .Include(o => o.Rule)
            .OrderByDescending(o => o.CreatedDate)
            .Take(10)
            .ToListAsync();
    }

    private Color GetHeatmapColor(double ratio) => ratio switch
    {
        >= 0.7 => Color.Error,
        >= 0.4 => Color.Warning,
        _ => Color.Info
    };

    public class ControversialSection
    {
        public string SectionTitle { get; set; } = "";
        public string DocTitle { get; set; } = "";
        public int TotalFeedback { get; set; }
        public int NegativeCount { get; set; }
        public double NegativeRatio => TotalFeedback == 0 ? 0 : (double)NegativeCount / TotalFeedback;
    }
}
