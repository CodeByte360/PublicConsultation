@page "/admin/reports/comparative/{DocumentId:guid}"
@attribute [Authorize(Roles = "Admin,Official")]
@using PublicConsultation.Core.Entities
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@inject ApplicationDbContext DbContext
@inject IAiAnalysisService AiService
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <div class="d-flex justify-space-between align-center mb-6 no-print">
        <div>
            <MudText Typo="Typo.h4">Comparative Statement</MudText>
            <MudText Typo="Typo.subtitle1">@_document?.Title</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Print"
            OnClick="PrintReport">Print / Export PDF</MudButton>
    </div>

    <div class="only-print mb-4">
        <MudText Typo="Typo.h4">Comparative Statement Report</MudText>
        <MudText Typo="Typo.h6">Document: @_document?.Title</MudText>
        <MudText Typo="Typo.subtitle1">Ministry: @_document?.MinistryOrDepartment</MudText>
        <MudDivider Class="my-2" />
    </div>

    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        <MudText>Generating Comprehensive AI Analysis...</MudText>
    }
    else if (_document != null)
    {
        <MudGrid Class="mb-6">
            <MudItem xs="12" md="3">
                <MudPaper Class="pa-4 text-center h-100" Elevation="2">
                    <MudText Typo="Typo.h6">Total Opinions</MudText>
                    <MudText Typo="Typo.h3" Color="Color.Primary">@_totalOpinions</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudPaper Class="pa-4 text-center h-100" Elevation="2">
                    <MudText Typo="Typo.h6">Global Sentiment</MudText>
                    <MudChip T="string" Color="@GetSentimentColor(_globalSentiment)" Size="Size.Large">@_globalSentiment
                    </MudChip>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 h-100" Elevation="2">
                    <MudText Typo="Typo.h6">Key Public Concerns</MudText>
                    @if (_globalThemes.Any())
                    {
                        @foreach (var theme in _globalThemes)
                        {
                            <MudChip T="string" Variant="Variant.Text" Color="Color.Secondary">@theme</MudChip>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">No dominant themes detected.</MudText>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudTable Items="@_reportRows" Hover="true" Bordered="true" Striped="true" Elevation="4" Dense="true">
            <HeaderContent>
                <MudTh Style="width: 100px;">Section</MudTh>
                <MudTh>Existing Provision</MudTh>
                <MudTh>Proposed Provision</MudTh>
                <MudTh Style="background-color: #fafafa;">Public Feedback (AI Analysis)</MudTh>
                <MudTh>Recommendation</MudTh>
                <MudTh Class="no-print">Ref. Opinions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Section">
                    <b>@context.Rule.RuleNumber</b><br />
                    <MudText Typo="Typo.caption">@context.Rule.SectionTitle</MudText>
                </MudTd>
                <MudTd DataLabel="Existing">
                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@context.Rule.ExistingProvision</MudText>
                </MudTd>
                <MudTd DataLabel="Proposed">
                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@context.Rule.ProposedProvision</MudText>
                </MudTd>
                <MudTd DataLabel="Analysis" Style="background-color: #fdfdfd;">
                    @if (context.IsProcessing)
                    {
                        <MudProgressLinear Color="Color.Success" Indeterminate="true" />
                    }
                    else
                    {
                        <div class="d-flex align-center mb-2">
                            <MudChip T="string" Size="Size.Small" Color="@GetSentimentColor(context.Analysis?.Sentiment)"
                                Class="mr-2">@context.Analysis?.Sentiment</MudChip>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Opinions.Count feedback(s)</MudText>
                        </div>
                        <MudText Typo="Typo.body2">@context.Analysis?.Summary</MudText>
                        @if (context.Analysis?.KeyThemes.Any() == true)
                        {
                            <div class="mt-2">
                                @foreach (var t in context.Analysis.KeyThemes)
                                {
                                    <span class="mud-typography mud-typography-caption px-1 mr-1"
                                        style="background:#eee; border-radius:4px;">#@t</span>
                                }
                            </div>
                        }
                    }
                </MudTd>
                <MudTd DataLabel="Recommendation">
                    <MudText Typo="Typo.body2"><b>@context.Analysis?.Recommendation</b></MudText>
                    <MudTextField T="string" Variant="Variant.Text" Margin="Margin.Dense"
                        Placeholder="Add final decision..." Class="mt-2 no-print" />
                </MudTd>
                <MudTd Class="no-print">
                    <MudTooltip Text="View raw opinions">
                        <MudIconButton Icon="@Icons.Material.Filled.List" Size="Size.Small" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudContainer>

<style>
    .only-print { display: none; }

    @@media print {
        .no-print { display: none !important; }
        .only-print { display: block !important; }
        .mud-container { max-width: 100% !important; margin: 0 !important; padding: 0 !important; }
        .mud-paper { box-shadow: none !important; border: 1px solid #eee; }
        .mud-table-container { overflow: visible !important; }
        .mud-appbar, .mud-drawer { display: none !important; }
        .mud-main-content { padding-top: 0 !important; margin-left: 0 !important; }
        body { background-color: white !important; }
    }
</style>

@code {
    [Parameter] public Guid DocumentId { get; set; }

    private DraftDocument? _document;
    private List<ReportRow> _reportRows = new();
    private bool _loading = true;
    private int _totalOpinions = 0;
    private string _globalSentiment = "Neutral";
    private List<string> _globalThemes = new();

    private class ReportRow
    {
        public Rule Rule { get; set; } = null!;
        public List<Opinion> Opinions { get; set; } = new();
        public AnalysisResultDto? Analysis { get; set; }
        public bool IsProcessing { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _document = await DbContext.DraftDocuments.FindAsync(DocumentId);

        if (_document != null)
        {
            var rules = await DbContext.Rules
            .Where(r => r.DraftDocumentId == DocumentId)
            .OrderBy(r => r.DisplayOrder)
            .ToListAsync();

            var allOpinions = await DbContext.Opinions
            .Where(o => o.Rule.DraftDocumentId == DocumentId)
            .ToListAsync();

            _totalOpinions = allOpinions.Count;

            foreach (var rule in rules)
            {
                var row = new ReportRow
                    {
                        Rule = rule,
                        Opinions = allOpinions.Where(o => o.RuleId == rule.Id).ToList(),
                        IsProcessing = true
                    };
                _reportRows.Add(row);
            }

            _loading = false;
            StateHasChanged();

            await ProcessAiSummaries();
            CalculateGlobalMetrics();
        }
    }

    private async Task ProcessAiSummaries()
    {
        foreach (var row in _reportRows)
        {
            row.Analysis = await AiService.AnalyzeBatchAsync(row.Opinions);
            row.IsProcessing = false;
            StateHasChanged();
            await Task.Delay(200);
        }
    }

    private void CalculateGlobalMetrics()
    {
        _globalThemes = _reportRows.Where(r => r.Analysis != null)
        .SelectMany(r => r.Analysis!.KeyThemes)
        .GroupBy(t => t)
        .OrderByDescending(g => g.Count())
        .Take(5)
        .Select(g => g.Key)
        .ToList();

        var sentiments = _reportRows.Where(r => r.Analysis != null).Select(r => r.Analysis!.Sentiment).ToList();
        if (sentiments.Count(s => s == "Negative") > sentiments.Count / 3) _globalSentiment = "Negative";
        else if (sentiments.Count(s => s == "Positive") > sentiments.Count / 2) _globalSentiment = "Positive";
        else _globalSentiment = "Mixed";
    }

    private Color GetSentimentColor(string? s) => s switch
    {
        "Positive" => Color.Success,
        "Negative" => Color.Error,
        "Mixed" => Color.Warning,
        _ => Color.Default
    };

    private async Task PrintReport()
    {
        await JSRuntime.InvokeVoidAsync("window.print");
    }
}
