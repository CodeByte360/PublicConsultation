@using PublicConsultation.Core.Entities
@using MudBlazor

<MudDialog>
    <TitleContent>
        <div class="d-flex justify-space-between align-center">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.ListAlt" Class="mr-3" Color="Color.Primary" />
                <div>
                    <MudText Typo="Typo.h6">Raw Opinions: Rule @RuleNumber</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="text-truncate"
                        Style="max-width: 400px; display: block;">@SectionTitle</MudText>
                </div>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="Close" />
        </div>
    </TitleContent>
    <DialogContent>
        @if (Opinions == null || !Opinions.Any())
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">No raw opinions submitted for this
                section yet.</MudAlert>
        }
        else
        {
            <div style="max-height: 600px; overflow-y: auto;" class="pr-2">
                @foreach (var opinion in Opinions)
                {
                    <MudPaper Class="pa-4 mb-4" Elevation="0"
                        Style="@($"border-left: 6px solid {GetColorHex(opinion.Sentiment)}; background-color: #fcfcfc; border-top: 1px solid #eee; border-right: 1px solid #eee; border-bottom: 2px solid #eee;")">
                        <div class="d-flex justify-space-between align-center mb-3">
                            <div class="d-flex align-center">
                                <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-3">
                                    @(opinion.User?.FullNameEnglish?.Substring(0, 1).ToUpper() ?? "U")
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.subtitle2"><b>@(opinion.User?.FullNameEnglish ?? "Unknown Citizen")</b>
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Verified Citizen</MudText>
                                </div>
                                <MudChip T="string" Size="Size.Small" Color="@GetSentimentColor(opinion.Sentiment)"
                                    Variant="Variant.Filled" Class="ml-4">@opinion.Sentiment</MudChip>
                            </div>
                            <div class="d-flex flex-column align-end">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Submitted on</MudText>
                                <MudText Typo="Typo.caption"><b>@opinion.CreatedDate.ToLongDateString()</b></MudText>
                            </div>
                        </div>

                        <MudDivider Class="mb-3" />

                        <MudText Typo="Typo.body2" Class="mb-3" Style="line-height: 1.6;">
                            @opinion.OpinionText
                        </MudText>

                        @if (!string.IsNullOrEmpty(opinion.Suggestion))
                        {
                            <MudPaper Class="pa-3" Elevation="0" Style="background-color: #f1f8e9; border: 1px dashed #2e7d32;">
                                <div class="d-flex align-center mb-1">
                                    <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Size="Size.Small" Color="Color.Success"
                                        Class="mr-2" />
                                    <MudText Typo="Typo.caption" Color="Color.Success"><b>PROPOSED REWORDING</b></MudText>
                                </div>
                                <MudText Typo="Typo.body2" Style="font-style: italic;">"@opinion.Suggestion"</MudText>
                            </MudPaper>
                        }
                    </MudPaper>
                }
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Text" OnClick="Close" Class="px-8">Close Details</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public List<Opinion> Opinions { get; set; } = new();
    [Parameter] public string RuleNumber { get; set; } = string.Empty;
    [Parameter] public string SectionTitle { get; set; } = string.Empty;

    private void Close() => MudDialog.Close();

    private Color GetSentimentColor(string? s)
    {
        if (string.IsNullOrEmpty(s)) return Color.Default;
        if (s.StartsWith("Positive")) return Color.Success;
        if (s.StartsWith("Negative")) return Color.Error;
        if (s.StartsWith("Mixed")) return Color.Warning;
        return Color.Default;
    }

    private string GetColorHex(string? s)
    {
        if (string.IsNullOrEmpty(s)) return "#e0e0e0";
        if (s.StartsWith("Positive")) return "#00c853";
        if (s.StartsWith("Negative")) return "#f44336";
        if (s.StartsWith("Mixed")) return "#ff9800";
        return "#e0e0e0";
    }
}
