@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using System.IO
@using Microsoft.AspNetCore.Components.Forms
@using PublicConsultation.BlazorServer.Pages.Components
@inject IFileService FileService
@inject IAuthService AuthService
@inject IBiometricService BiometricService
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex justify-space-between align-center">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Class="mr-3" Color="Color.Primary" />
                <div>
                    <MudText Typo="Typo.h6">Edit User Account</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Update security permissions and profile information for <b>@model.Email</b>.</MudText>
                </div>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="Cancel" />
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success" Class="pt-4">
            <MudGrid>
                <MudItem xs="12" md="4" class="d-flex flex-column align-center justify-start">
                    <MudAvatar Color="Color.Primary" Style="height:120px; width:120px; font-size:3.5rem;" Class="mb-4 shadow-sm">
                        @if (!string.IsNullOrEmpty(model.ProfilePictureUrl))
                        {
                            <MudImage Src="@model.ProfilePictureUrl" Style="height:100%; width:100%; object-fit:cover;" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                        }
                    </MudAvatar>
                    <MudFileUpload T="IBrowserFile" OnFilesChanged="UploadFiles">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.CloudUpload" Size="Size.Small">
                                Change Photo
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                </MudItem>

                <MudItem xs="12" md="8">
                    <MudGrid>

                        <MudItem xs="12" sm="6">
                            <MudTextField T="string" Label="Email Address" Required="true" InputType="InputType.Email"
                                          @bind-Value="model.Email" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField T="string" Label="New Password (Optional)" InputType="@(_passwordVisible ? InputType.Text : InputType.Password)"
                                          @bind-Value="newPassword" Variant="Variant.Outlined" Margin="Margin.Dense" 
                                          Placeholder="Leave blank to keep current"
                                          Adornment="Adornment.End" AdornmentIcon="@_passwordInputIcon" OnAdornmentClick="TogglePasswordVisibility" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="Guid" Label="Assign Role" Required="true" @bind-Value="model.RoleId"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" 
                                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Security"
                                       Placeholder="Select Role">
                                @foreach (var role in Roles)
                                {
                                    <MudSelectItem T="Guid" Value="@role.Oid">@role.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudItem>

                <MudItem xs="12"><MudDivider Class="my-2"/></MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Full Name (English)" @bind-Value="model.FullNameEnglish" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Full Name (English) is required!" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Full Name (Bangla)" @bind-Value="model.FullNameBangla" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Designation / Title" @bind-Value="model.Designation" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Mobile Number" @bind-Value="model.PhoneNumber" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Mobile Number is required!" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="long" Label="NID Number" @bind-Value="model.NIDNumber" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="NID Number is required!" 
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField T="string" Label="Business / Residential Address" @bind-Value="model.Address" Lines="2" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-1">Location Details (Hierarchy)</MudText>
                    <MudDivider Class="mb-4" />
                    <LocationSelector PoliceStationId="model.PoliceStationId" PoliceStationIdChanged="(val) => model.PoliceStationId = val" />
                </MudItem>

                <MudItem xs="12"><MudDivider Class="my-2"/></MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Class="mr-2" />
                        Update Biometric Data
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Scan a finger to update/register it. Existing data is preserved unless overwritten.</MudText>
                    
                    <MudGrid Spacing="3" Class="mt-2">
                        <MudItem xs="12" sm="6" md="3">
                            <PublicConsultation.BlazorServer.Pages.Components.FingerprintCapture Label="Left Thumb"
                                IsRegistered="@(!string.IsNullOrEmpty(existingBiometric?.LeftThumb))"
                                OnCaptured="@(data => { leftThumbTemplate = data.Template; leftThumbImage = data.Image; })"
                                ImageData="@leftThumbImage" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <PublicConsultation.BlazorServer.Pages.Components.FingerprintCapture Label="Left Index"
                                IsRegistered="@(!string.IsNullOrEmpty(existingBiometric?.LeftIndex))"
                                OnCaptured="@(data => { leftIndexTemplate = data.Template; leftIndexImage = data.Image; })"
                                ImageData="@leftIndexImage" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <PublicConsultation.BlazorServer.Pages.Components.FingerprintCapture Label="Right Thumb"
                                IsRegistered="@(!string.IsNullOrEmpty(existingBiometric?.RightThumb))"
                                OnCaptured="@(data => { rightThumbTemplate = data.Template; rightThumbImage = data.Image; })"
                                ImageData="@rightThumbImage" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <PublicConsultation.BlazorServer.Pages.Components.FingerprintCapture Label="Right Index"
                                IsRegistered="@(!string.IsNullOrEmpty(existingBiometric?.RightIndex))"
                                OnCaptured="@(data => { rightIndexTemplate = data.Template; rightIndexImage = data.Image; })"
                                ImageData="@rightIndexImage" />
                        </MudItem>
                    </MudGrid>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Class="px-6">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" 
                   Disabled="@(!success)" StartIcon="@Icons.Material.Filled.Save" Class="px-8">
            Update Account
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public UserAccount User { get; set; }

    MudForm form;
    bool success;
    UserAccount model = new UserAccount();
    string newPassword;
    List<Role> Roles = new List<Role>();
    bool _passwordVisible = false;
    string _passwordInputIcon => _passwordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    Biometric? existingBiometric;
    string? leftThumbImage, leftThumbTemplate;
    string? leftIndexImage, leftIndexTemplate;
    string? rightThumbImage, rightThumbTemplate;
    string? rightIndexImage, rightIndexTemplate;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Roles = await context.Roles.AsNoTracking().ToListAsync();
        existingBiometric = await BiometricService.GetBiometricByUserIdAsync(User.Oid);

        // Map existing user to model
        model.Oid = User.Oid;
        model.RoleId = User.RoleId;
        model.ProfilePictureUrl = User.ProfilePictureUrl;
        model.FullNameEnglish = User.FullNameEnglish;
        model.FullNameBangla = User.FullNameBangla;
        model.Email = User.Email;
        model.PhoneNumber = User.PhoneNumber;
        model.NIDNumber = User.NIDNumber;
        model.Designation = User.Designation;
        model.Address = User.Address;
        model.PoliceStationId = User.PoliceStationId;
    }

    private void TogglePasswordVisibility()
    {
        _passwordVisible = !_passwordVisible;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task UploadFiles(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            try
            {
                var maxFileSize = 5 * 1024 * 1024;
                using var stream = file.OpenReadStream(maxFileSize);
                var url = await FileService.UploadProfilePictureAsync(stream, file.Name);
                model.ProfilePictureUrl = url;
                StateHasChanged();
                Snackbar.Add("Picture uploaded. Remember to save changes.", MudBlazor.Severity.Info);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Upload failed: {ex.Message}", MudBlazor.Severity.Error);
            }
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid)
        {
            try
            {
                // Uniqueness checks (excluding current user)
                if (!await AuthService.IsEmailUniqueAsync(model.Email, model.Oid))
                {
                    Snackbar.Add("Email address is already in use by another user.", Severity.Error);
                    return;
                }
                if (!await AuthService.IsPhoneUniqueAsync(model.PhoneNumber, model.Oid))
                {
                    Snackbar.Add("Phone number is already in use by another user.", Severity.Error);
                    return;
                }
                if (!await AuthService.IsNidUniqueAsync(model.NIDNumber, model.Oid))
                {
                    Snackbar.Add("NID number is already in use by another user.", Severity.Error);
                    return;
                }

                using var context = DbFactory.CreateDbContext();
                var userToUpdate = await context.UserAccounts.FindAsync(model.Oid);
                if (userToUpdate == null)
                {
                    Snackbar.Add("User not found.", Severity.Error);
                    return;
                }

                // Update properties
                userToUpdate.Email = model.Email;
                userToUpdate.FullNameEnglish = model.FullNameEnglish;
                userToUpdate.FullNameBangla = model.FullNameBangla;
                userToUpdate.Designation = model.Designation;
                userToUpdate.PhoneNumber = model.PhoneNumber;
                userToUpdate.NIDNumber = model.NIDNumber;
                userToUpdate.Address = model.Address;
                userToUpdate.PoliceStationId = model.PoliceStationId;
                userToUpdate.RoleId = model.RoleId;
                userToUpdate.ProfilePictureUrl = model.ProfilePictureUrl;

                if (!string.IsNullOrWhiteSpace(newPassword))
                {
                    userToUpdate.PasswordHash = AuthService.HashPassword(newPassword);
                }

                context.UserAccounts.Update(userToUpdate);
                await context.SaveChangesAsync();

                // Handle Biometric Updates
                bool bioChanged = false;
                var bio = existingBiometric ?? new Biometric { Oid = Guid.NewGuid(), UserAccountId = model.Oid };
                
                if (!string.IsNullOrEmpty(leftThumbTemplate)) { bio.LeftThumb = leftThumbTemplate; bioChanged = true; }
                if (!string.IsNullOrEmpty(leftIndexTemplate)) { bio.LeftIndex = leftIndexTemplate; bioChanged = true; }
                if (!string.IsNullOrEmpty(rightThumbTemplate)) { bio.RightThumb = rightThumbTemplate; bioChanged = true; }
                if (!string.IsNullOrEmpty(rightIndexTemplate)) { bio.RightIndex = rightIndexTemplate; bioChanged = true; }

                if (bioChanged)
                {
                    if (existingBiometric == null)
                    {
                        await BiometricService.SaveBiometricAsync(bio);
                    }
                    else
                    {
                        await BiometricService.UpdateBiometricAsync(bio);
                    }
                }

                Snackbar.Add("User account updated successfully!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}
