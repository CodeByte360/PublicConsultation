@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using System.IO
@using Microsoft.AspNetCore.Components.Forms
@inject IFileService FileService
@inject IAuthService AuthService
@inject ISnackbar Snackbar
@using PublicConsultation.BlazorServer.Pages.Components
@inject IBiometricService BiometricService
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<MudDialog>
    <TitleContent>
        <div class="d-flex justify-space-between align-center">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-3" Color="Color.Primary" />
                <div>
                    <MudText Typo="Typo.h6">Create System User</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Register a new administrator, official, or
                        citizen account.</MudText>
                </div>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="Cancel" />
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success" Class="pt-4">
            <MudGrid>
                <MudItem xs="12" md="4" class="d-flex flex-column align-center justify-center">
                    <MudAvatar Color="Color.Primary" Style="height:120px; width:120px; font-size:3.5rem;"
                        Class="mb-4 shadow-sm">
                        @if (!string.IsNullOrEmpty(model.ProfilePictureUrl))
                        {
                            <MudImage Src="@model.ProfilePictureUrl" Style="height:100%; width:100%; object-fit:cover;" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                        }
                    </MudAvatar>
                    <MudFileUpload T="IBrowserFile" OnFilesChanged="UploadFiles">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                StartIcon="@Icons.Material.Filled.CloudUpload" Size="Size.Small">
                                Upload Photo
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                </MudItem>

                <MudItem xs="12" md="8">
                    <MudGrid>

                        <MudItem xs="12" sm="6">
                            <MudTextField T="string" Label="Email Address" Required="true" InputType="InputType.Email"
                            @bind-Value="model.Email" Variant="Variant.Outlined" Margin="Margin.Dense"
                                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField T="string" Label="Password" Required="true" InputType="InputType.Password"
                            @bind-Value="password" Variant="Variant.Outlined" Margin="Margin.Dense"
                                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="Guid" Label="Assign Role" Required="true" @bind-Value="selectedRoleId"
                                Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter"
                                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Security">
                                @foreach (var role in Roles)
                                {
                                    <MudSelectItem Value="@role.Oid">@role.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Full Name (English)" @bind-Value="model.FullNameEnglish"
                        Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Full Name (Bangla)" @bind-Value="model.FullNameBangla"
                        Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Designation / Title" @bind-Value="model.Designation"
                        Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Mobile Number" @bind-Value="model.PhoneNumber"
                        Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="NID Number" @bind-Value="model.NIDNumber" Variant="Variant.Outlined"
                        Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField T="string" Label="Business / Residential Address" @bind-Value="model.Address"
                        Lines="2" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-1">Location Details (Hierarchy)
                    </MudText>
                    <MudDivider Class="mb-4" />
                    <LocationSelector PoliceStationId="model.PoliceStationId"
                        PoliceStationIdChanged="(val) => model.PoliceStationId = val" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Class="mr-2" />
                        Biometric Registration
                    </MudText>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" sm="6" md="3">
                            <PublicConsultation.BlazorServer.Pages.Components.FingerprintCapture Label="Left Thumb"
                                OnCaptured="@(data => { leftThumbTemplate = data.Template; leftThumbImage = data.Image; })"
                                ImageData="@leftThumbImage" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <PublicConsultation.BlazorServer.Pages.Components.FingerprintCapture Label="Left Index"
                                OnCaptured="@(data => { leftIndexTemplate = data.Template; leftIndexImage = data.Image; })"
                                ImageData="@leftIndexImage" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <PublicConsultation.BlazorServer.Pages.Components.FingerprintCapture Label="Right Thumb"
                                OnCaptured="@(data => { rightThumbTemplate = data.Template; rightThumbImage = data.Image; })"
                                ImageData="@rightThumbImage" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <PublicConsultation.BlazorServer.Pages.Components.FingerprintCapture Label="Right Index"
                                OnCaptured="@(data => { rightIndexTemplate = data.Template; rightIndexImage = data.Image; })"
                                ImageData="@rightIndexImage" />
                        </MudItem>
                    </MudGrid>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Class="px-6">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!success)"
            StartIcon="@Icons.Material.Filled.PersonAdd" Class="px-8">
            Create Account
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    MudForm form;
    bool success;
    UserAccount model = new UserAccount();
    string password;
    Guid selectedRoleId;
    List<Role> Roles = new List<Role>();

    string? leftThumbTemplate, leftIndexTemplate, rightThumbTemplate, rightIndexTemplate;
    string? leftThumbImage, leftIndexImage, rightThumbImage, rightIndexImage;


    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Roles = await context.Roles.AsNoTracking().ToListAsync();
        // Default to Citizen if available
        var citizen = Roles.FirstOrDefault(r => r.Name == "Citizen");
        if (citizen != null) selectedRoleId = citizen.Oid;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task UploadFiles(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            try
            {
                var maxFileSize = 5 * 1024 * 1024;
                using var stream = file.OpenReadStream(maxFileSize);
                var url = await FileService.UploadProfilePictureAsync(stream, file.Name);
                model.ProfilePictureUrl = url;
                StateHasChanged();
                Snackbar.Add("Picture uploaded.", MudBlazor.Severity.Info);
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Upload failed: {ex.Message}", MudBlazor.Severity.Error);
            }
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid)
        {
            try
            {
                model.IsVerified = true; // Admin created users are verified by default
                var registeredUser = await AuthService.RegisterUserAsync(model, password, selectedRoleId);

                if (registeredUser != null && (!string.IsNullOrEmpty(leftThumbTemplate) || !string.IsNullOrEmpty(leftIndexTemplate) ||
                !string.IsNullOrEmpty(rightThumbTemplate) || !string.IsNullOrEmpty(rightIndexTemplate)))
                {
                    var biometric = new Biometric
                        {
                            UserAccountId = registeredUser.Oid,
                            LeftThumb = leftThumbTemplate,
                            LeftIndex = leftIndexTemplate,
                            RightThumb = rightThumbTemplate,
                            RightIndex = rightIndexTemplate
                        };
                    await BiometricService.SaveBiometricAsync(biometric);
                }

                Snackbar.Add("User created successfully!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}
