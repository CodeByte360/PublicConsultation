@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using System.IO
@using Microsoft.AspNetCore.Components.Forms
@inject IFileService FileService
@inject IAuthService AuthService
@inject ApplicationDbContext DbContext
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success">
            <div class="d-flex flex-column align-center mb-4">
                <MudAvatar Color="Color.Primary" Style="height:100px; width:100px; font-size:3rem;" Class="mb-2">
                    @if (!string.IsNullOrEmpty(model.ProfilePictureUrl))
                    {
                        <MudImage Src="@model.ProfilePictureUrl" Style="height:100%; width:100%; object-fit:cover;" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                    }
                </MudAvatar>
                <MudFileUpload T="IBrowserFile" OnFilesChanged="UploadFiles">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                            StartIcon="@Icons.Material.Filled.CloudUpload">
                            Upload Photo
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
            </div>

            <MudTextField T="string" Label="Username" Required="true" @bind-Value="model.Username" />
            <MudTextField T="string" Label="Email" Required="true" InputType="InputType.Email"
            @bind-Value="model.Email" />
            <MudTextField T="string" Label="Password" Required="true" InputType="InputType.Password"
            @bind-Value="password" />

            <MudSelect T="Guid" Label="Role" Required="true" @bind-Value="selectedRoleId"
                AnchorOrigin="Origin.BottomCenter">
                @foreach (var role in Roles)
                {
                    <MudSelectItem Value="@role.Oid">@role.Name</MudSelectItem>
                }
            </MudSelect>

            <MudTextField T="string" Label="Full Name (English)" @bind-Value="model.FullNameEnglish" />
            <MudTextField T="string" Label="Full Name (Bangla)" @bind-Value="model.FullNameBangla" />
            <MudTextField T="string" Label="Designation" @bind-Value="model.Designation" />
            <MudTextField T="string" Label="Mobile Number" @bind-Value="model.PhoneNumber" />
            <MudTextField T="string" Label="NID Number" @bind-Value="model.NIDNumber" />

            <MudGrid>
                <MudItem xs="6">
                    <MudTextField T="string" Label="Division" @bind-Value="model.Division" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField T="string" Label="District" @bind-Value="model.District" />
                </MudItem>
            </MudGrid>
            <MudTextField T="string" Label="Address" @bind-Value="model.Address" Lines="2" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!success)">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    MudForm form;
    bool success;
    UserAccount model = new UserAccount();
    string password;
    Guid selectedRoleId;
    List<Role> Roles = new List<Role>();

    protected override async Task OnInitializedAsync()
    {
        Roles = await DbContext.Roles.ToListAsync();
        // Default to Citizen if available
        var citizen = Roles.FirstOrDefault(r => r.Name == "Citizen");
        if (citizen != null) selectedRoleId = citizen.Oid;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task UploadFiles(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            try
            {
                var maxFileSize = 5 * 1024 * 1024;
                using var stream = file.OpenReadStream(maxFileSize);
                var url = await FileService.UploadProfilePictureAsync(stream, file.Name);
                model.ProfilePictureUrl = url;
                StateHasChanged();
                Snackbar.Add("Picture uploaded.", MudBlazor.Severity.Info);
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Upload failed: {ex.Message}", MudBlazor.Severity.Error);
            }
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid)
        {
            try
            {
                model.IsVerified = true; // Admin created users are verified by default
                await AuthService.RegisterUserAsync(model, password, selectedRoleId);
                Snackbar.Add("User created successfully!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}
