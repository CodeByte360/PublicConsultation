@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@using PublicConsultation.Core.DTOs
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using System.IO
@using Microsoft.AspNetCore.Components.Forms
@inject IFileService FileService
@inject IAuthService AuthService
@inject IEmailService EmailService
@inject IOtpService OtpService
@inject ISnackbar Snackbar
@using PublicConsultation.BlazorServer.Pages.Components
@inject IBiometricService BiometricService
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<MudDialog>
    <TitleContent>
        <div class="d-flex justify-space-between align-center">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-3" Color="Color.Primary" />
                <div>
                    <MudText Typo="Typo.h6">Create System User</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Register a new administrator, official, or
                        citizen account.</MudText>
                </div>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="Cancel" />
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success" Class="pt-4">
            <MudGrid>
                <MudItem xs="12" md="4" class="d-flex flex-column align-center justify-center">
                    <MudAvatar Color="Color.Primary" Style="height:120px; width:120px; font-size:3.5rem;"
                        Class="mb-4 shadow-sm">
                        @if (!string.IsNullOrEmpty(model.ProfilePictureUrl))
                        {
                            <MudImage Src="@model.ProfilePictureUrl" Style="height:100%; width:100%; object-fit:cover;" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                        }
                    </MudAvatar>
                    <MudFileUpload T="IBrowserFile" OnFilesChanged="UploadFiles">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                StartIcon="@Icons.Material.Filled.CloudUpload" Size="Size.Small">
                                Upload Photo
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                </MudItem>

                <MudItem xs="12" md="8">
                    <MudGrid>

                        <MudItem xs="12" sm="6">
                            <MudTextField T="string" Label="Email Address" Required="true" InputType="InputType.Email"
                            @bind-Value="model.Email" Variant="Variant.Outlined" Margin="Margin.Dense"
                                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email"
                                Disabled="@isEmailVerified" />
                        </MudItem>

                        <MudItem xs="12" sm="6" Class="d-flex align-center">
                            @if (!isEmailVerified)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="SendOtp"
                                    Disabled="@(string.IsNullOrEmpty(model.Email) || isOtpSent)" Class="mr-2"
                                    Size="Size.Small">
                                    @(isOtpSent ? "OTP Sent" : "Send OTP")
                                </MudButton>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle"
                                    Size="Size.Small">Verified</MudChip>
                            }
                        </MudItem>

                        @if (isOtpSent && !isEmailVerified)
                        {
                            <MudItem xs="12" sm="6">
                                <MudTextField T="string" Label="Enter OTP" @bind-Value="otpInput" Variant="Variant.Outlined"
                                    Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6" Class="d-flex align-center">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="VerifyOtp"
                                    Size="Size.Small">Verify OTP</MudButton>
                            </MudItem>
                        }

                        <MudItem xs="12" sm="6">
                            <MudTextField T="string" Label="Password" Required="true" InputType="InputType.Password"
                            @bind-Value="model.Password" Variant="Variant.Outlined" Margin="Margin.Dense"
                                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="Guid" Label="Assign Role" Required="true" @bind-Value="model.RoleId"
                                Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter"
                                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Security">
                                @foreach (var role in Roles)
                                {
                                    <MudSelectItem Value="@role.Oid">@role.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Full Name (English)" @bind-Value="model.FullNameEnglish"
                        Variant="Variant.Outlined" Margin="Margin.Dense" Required="true"
                        RequiredError="Full Name (English) is required!" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Full Name (Bangla)" @bind-Value="model.FullNameBangla"
                        Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Designation / Title" @bind-Value="model.Designation"
                        Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Mobile Number" @bind-Value="model.PhoneNumber"
                        Variant="Variant.Outlined" Margin="Margin.Dense" Required="true"
                        RequiredError="Mobile Number is required!" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="long" Label="NID Number" @bind-Value="model.NIDNumber" Variant="Variant.Outlined"
                        Margin="Margin.Dense" Required="true" RequiredError="NID Number is required!"
                        Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField T="string" Label="Business / Residential Address" @bind-Value="model.Address"
                        Lines="2" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-1">Location Details (Hierarchy)
                    </MudText>
                    <MudDivider Class="mb-4" />
                    <LocationSelector PoliceStationId="model.PoliceStationId"
                        PoliceStationIdChanged="(val) => model.PoliceStationId = val" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Class="mr-2" />
                        Biometric Registration
                    </MudText>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" sm="6" md="3">
                            <PublicConsultation.BlazorServer.Pages.Components.FingerprintCapture Label="Left Thumb"
                                OnCaptured="@(data => { leftThumbTemplate = data.Template; leftThumbImage = data.Image; })"
                                ImageData="@leftThumbImage" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <PublicConsultation.BlazorServer.Pages.Components.FingerprintCapture Label="Left Index"
                                OnCaptured="@(data => { leftIndexTemplate = data.Template; leftIndexImage = data.Image; })"
                                ImageData="@leftIndexImage" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <PublicConsultation.BlazorServer.Pages.Components.FingerprintCapture Label="Right Thumb"
                                OnCaptured="@(data => { rightThumbTemplate = data.Template; rightThumbImage = data.Image; })"
                                ImageData="@rightThumbImage" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <PublicConsultation.BlazorServer.Pages.Components.FingerprintCapture Label="Right Index"
                                OnCaptured="@(data => { rightIndexTemplate = data.Template; rightIndexImage = data.Image; })"
                                ImageData="@rightIndexImage" />
                        </MudItem>
                    </MudGrid>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Class="px-6">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
            Disabled="@(!success || !isEmailVerified)" StartIcon="@Icons.Material.Filled.PersonAdd" Class="px-8">
            Create Account
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    MudForm form;
    bool success;
    CreateUserRequest model = new CreateUserRequest();
    List<Role> Roles = new List<Role>();

    string? leftThumbTemplate, leftIndexTemplate, rightThumbTemplate, rightIndexTemplate;
    string? leftThumbImage, leftIndexImage, rightThumbImage, rightIndexImage;

    // OTP State
    bool isOtpSent = false;
    bool isEmailVerified = false;
    string otpInput = "";

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Roles = await context.Roles.AsNoTracking().ToListAsync();
        // Default to Citizen if available
        var citizen = Roles.FirstOrDefault(r => r.Name == "Citizen");
        if (citizen != null) model.RoleId = citizen.Oid;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task UploadFiles(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            try
            {
                var maxFileSize = 5 * 1024 * 1024;
                using var stream = file.OpenReadStream(maxFileSize);
                var url = await FileService.UploadProfilePictureAsync(stream, file.Name);
                model.ProfilePictureUrl = url;
                StateHasChanged();
                Snackbar.Add("Picture uploaded.", MudBlazor.Severity.Info);
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Upload failed: {ex.Message}", MudBlazor.Severity.Error);
            }
        }
    }

    private async Task SendOtp()
    {
        if (string.IsNullOrEmpty(model.Email))
        {
            Snackbar.Add("Please enter an email address.", Severity.Warning);
            return;
        }

        try
        {
            var otp = await OtpService.GenerateOtpAsync(model.Email);
            await EmailService.SendEmailAsync(model.Email, "Public Consultation - Email Verification",
            $"Your OTP for registration is: <b>{otp}</b>. It expires in 5 minutes.");

            isOtpSent = true;
            Snackbar.Add("OTP sent to email.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to send OTP: {ex.Message}", Severity.Error);
        }
    }

    private async Task VerifyOtp()
    {
        var isValid = await OtpService.ValidateOtpAsync(model.Email, otpInput);
        if (isValid)
        {
            isEmailVerified = true;
            isOtpSent = false;
            Snackbar.Add("Email verified successfully!", Severity.Success);
        }
        else
        {
            Snackbar.Add("Invalid or expired OTP.", Severity.Error);
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid && isEmailVerified)
        {
            try
            {
                // Uniqueness checks
                if (!await AuthService.IsEmailUniqueAsync(model.Email))
                {
                    Snackbar.Add("Email address is already in use.", Severity.Error);
                    return;
                }
                if (!await AuthService.IsPhoneUniqueAsync(model.PhoneNumber))
                {
                    Snackbar.Add("Phone number is already in use.", Severity.Error);
                    return;
                }
                if (!await AuthService.IsNidUniqueAsync(model.NIDNumber))
                {
                    Snackbar.Add("NID number is already in use.", Severity.Error);
                    return;
                }

                // Map DTO to Entity
                var user = new UserAccount
                    {
                        Email = model.Email,
                        FullNameEnglish = model.FullNameEnglish,
                        FullNameBangla = model.FullNameBangla,
                        PhoneNumber = model.PhoneNumber,
                        NIDNumber = model.NIDNumber,
                        Designation = model.Designation,
                        Address = model.Address,
                        PoliceStationId = model.PoliceStationId,
                        ProfilePictureUrl = model.ProfilePictureUrl,
                        IsVerified = true,
                        IsActive = true
                    };

                var registeredUser = await AuthService.RegisterUserAsync(user, model.Password, model.RoleId);

                if (registeredUser != null && (!string.IsNullOrEmpty(leftThumbTemplate) || !string.IsNullOrEmpty(leftIndexTemplate) ||
                !string.IsNullOrEmpty(rightThumbTemplate) || !string.IsNullOrEmpty(rightIndexTemplate)))
                {
                    var biometric = new Biometric
                        {
                            UserAccountId = registeredUser.Oid,
                            LeftThumb = leftThumbTemplate,
                            LeftIndex = leftIndexTemplate,
                            RightThumb = rightThumbTemplate,
                            RightIndex = rightIndexTemplate
                        };
                    await BiometricService.SaveBiometricAsync(biometric);
                }

                Snackbar.Add("User created successfully!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"{ex.Message}", Severity.Error);
            }
        }
    }
}
