@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@using PublicConsultation.Core.Entities
@using PublicConsultation.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@inject IAuthService AuthService
@inject ApplicationDbContext DbContext
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h5">User Management</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateUser">Create User</MudButton>
    </div>

    <MudTable Items="@Users" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading"
        LoadingProgressColor="Color.Info">
        <HeaderContent>
            <MudTh>Username</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Full Name</MudTh>
            <MudTh>Role</MudTh>
            <MudTh>Verified</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Username">@context.Username</MudTd>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Full Name">@context.FullNameEnglish</MudTd>
            <MudTd DataLabel="Role">
                <MudChip T="string" Color="Color.Primary" Size="Size.Small">@context.Role?.Name</MudChip>
            </MudTd>
            <MudTd DataLabel="Verified">
                @if (context.IsVerified)
                {
                    <MudTooltip Text="Click to Unverify">
                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success"
                            OnClick="@(() => ToggleVerification(context))" />
                    </MudTooltip>
                }
                else
                {
                    <MudTooltip Text="Click to Verify">
                        <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error"
                            OnClick="@(() => ToggleVerification(context))" />
                    </MudTooltip>
                }
            </MudTd>
            <MudTd DataLabel="Status">
                <MudSwitch T="bool" @bind-Value="@context.IsActive" Color="Color.Success"
                    Converter="@(new StatusConverter(DbContext, Snackbar))"
                    Label="@(context.IsActive ? "Active" : "Inactive")" />
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info"
                    OnClick="@(() => EditUser(context))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>

@code {
    private List<UserAccount> Users = new List<UserAccount>();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _loading = true;
        Users = await DbContext.UserAccounts.Include(u => u.Role).OrderBy(u => u.Username).ToListAsync();
        _loading = false;
    }

    private async Task CreateUser()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<CreateUserDialog>("Create New User", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadUsers();
        }
    }

    private async Task EditUser(UserAccount user)
    {
        var parameters = new DialogParameters { ["User"] = user };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<EditUserDialog>("Edit User", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadUsers();
        }
    }

    private async Task ToggleVerification(UserAccount user)
    {
        var parameters = new DialogParameters { ["User"] = user };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };

        var dialog = DialogService.Show<VerificationDialog>(
        user.IsVerified ? "Unverify User?" : "Verify User Identity",
        parameters,
        options);

        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var originalStatus = user.IsVerified;
            user.IsVerified = !user.IsVerified;

            try
            {
                DbContext.UserAccounts.Update(user);
                await DbContext.SaveChangesAsync();
                Snackbar.Add($"User {(user.IsVerified ? "verified" : "unverified")} successfully.", Severity.Success);
            }
            catch (Exception ex)
            {
                user.IsVerified = originalStatus; // Revert on failure
                Snackbar.Add($"Error updating user verification: {ex.Message}", Severity.Error);
            }
        }
    }

    private class StatusConverter : BoolConverter<bool>
    {
        private readonly ApplicationDbContext _db;
        private readonly ISnackbar _snackbar;

        public StatusConverter(ApplicationDbContext db, ISnackbar snackbar)
        {
            _db = db;
            _snackbar = snackbar;

            SetFunc = (val) =>
            {
                // This is called when the switch is toggled.
                // However, MudSwitch with @bind-Value handles the update.
                // We want to trigger the DB save.
                return val;
            };
        }
    }

    private async Task OnStatusChanged(UserAccount user)
    {
        try
        {
            DbContext.UserAccounts.Update(user);
            await DbContext.SaveChangesAsync();
            Snackbar.Add($"User {(user.IsActive ? "activated" : "deactivated")} successfully.", Severity.Success);
        }
        catch (Exception ex)
        {
            user.IsActive = !user.IsActive; // Revert
            Snackbar.Add($"Error updating status: {ex.Message}", Severity.Error);
        }
    }
}
