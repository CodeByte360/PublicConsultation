@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" GutterBottom="true">Is this the correct citizen?</MudText>
        <MudText Class="mb-4">Please verify the details below match the citizen's documents.</MudText>

        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudField Label="Full Name (English)" Variant="Variant.Outlined">@User.FullNameEnglish</MudField>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudField Label="Full Name (Bangla)" Variant="Variant.Outlined">@User.FullNameBangla</MudField>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudField Label="NID Number" Variant="Variant.Outlined">@User.NIDNumber</MudField>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudField Label="Mobile Number" Variant="Variant.Outlined">@User.PhoneNumber</MudField>
            </MudItem>
            <MudItem xs="12">
                <MudField Label="Email" Variant="Variant.Outlined">@User.Email</MudField>
            </MudItem>
            <MudItem xs="12">
                <MudField Label="Address" Variant="Variant.Outlined">@User.Address</MudField>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="@(User.IsVerified ? Color.Error : Color.Success)" Variant="Variant.Filled" OnClick="Submit">
            @(User.IsVerified ? "Confirm Unverify" : "Confirm Verify")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public UserAccount User { get; set; }

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(true));
}
