@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@inject IMinistryService MinistryService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="mr-3" Color="Color.Primary" />
            <div>
                <MudText Typo="Typo.h6">@(Ministry.Oid == Guid.Empty ? "Register New Ministry" : "Update Ministry Details")</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Manage the ministries and departments involved in consultations.</MudText>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success" Class="pt-4">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField T="string" Label="Ministry Name" Required="true" @bind-Value="Ministry.Name" 
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Title" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" Label="Description / Mandate" Lines="4" @bind-Value="Ministry.Description"
                                  Variant="Variant.Outlined" Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Description" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Class="px-6">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" 
                   StartIcon="@Icons.Material.Filled.Save" Class="px-8">
            @(Ministry.Oid == Guid.Empty ? "Register" : "Update")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public Ministry Ministry { get; set; } = new Ministry();

    MudForm form;
    bool success;

    void Cancel() => MudDialog.Cancel();

    async Task Submit()
    {
        await form.Validate();
        if (success)
        {
            try
            {
                if (Ministry.Oid == Guid.Empty)
                {
                    // This case might not be hit if new Ministry are initialized with Guid.NewGuid() in constructor
                    // But if Ministry comes from externally it might be empty.
                    // Actually BaseEntity initializes Id.
                    // Logic should depend on how the dialog is invoked.
                }

                // The caller handles the actual Save/Update call to service usually,
                // OR we do it here. Let's do it here for simplicity if we want, or return the object.
                // Returning the object is better for separation.

                MudDialog.Close(DialogResult.Ok(Ministry));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}
