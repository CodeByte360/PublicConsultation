@page "/admin/ministries"
@attribute [Authorize(Roles = "Admin")]
@using PublicConsultation.Core.Entities
@using PublicConsultation.Core.Interfaces
@inject IMinistryService MinistryService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4"></MudBreadcrumbs>

    <MudPaper Elevation="4" Class="pa-4">
        <div class="d-flex justify-space-between align-center mb-4">
            <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 600;">Ministries</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateDialog"
                StartIcon="@Icons.Material.Filled.Add" Class="rounded-pill px-4">
                Add Ministry
            </MudButton>
        </div>

        <MudTable Items="@Ministries" Hover="true" Striped="true" Filter="new Func<Ministry,bool>(FilterFunc)"
            Elevation="0">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Ministry List</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start"
                    AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"
                    Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>
                    <MudTableSortLabel SortBy="new Func<Ministry, object>(x => x.Name)">Name</MudTableSortLabel>
                </MudTh>
                <MudTh>Description</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <MudText Typo="Typo.body1" Style="font-weight: 500;">@context.Name</MudText>
                </MudTd>
                <MudTd DataLabel="Description">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@context.Description</MudText>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                        OnClick="@(() => OpenEditDialog(context))" Class="mr-2" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                        OnClick="@(() => Delete(context))" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    private List<Ministry> Ministries = new();
    private string searchString = "";

    private List<BreadcrumbItem> _breadcrumbs = new List<BreadcrumbItem>
{
new BreadcrumbItem("Admin", href: null, disabled: true),
new BreadcrumbItem("Ministries", href: "/admin/ministries", disabled: false),
};

    protected override async Task OnInitializedAsync()
    {
        await LoadMinistries();
    }

    private async Task LoadMinistries()
    {
        Ministries = await MinistryService.GetAllMinistriesAsync();
    }

    private bool FilterFunc(Ministry element) => FilterFunc(element, searchString);

    private bool FilterFunc(Ministry element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<MinistryDialog>("Add Ministry", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var newMinistry = (Ministry)result.Data;
            await MinistryService.CreateMinistryAsync(newMinistry);
            Snackbar.Add("Ministry created successfully", Severity.Success);
            await LoadMinistries();
        }
    }

    private async Task OpenEditDialog(Ministry ministry)
    {
        var parameters = new DialogParameters { ["Ministry"] = ministry };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<MinistryDialog>("Edit Ministry", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var updatedMinistry = (Ministry)result.Data;
            await MinistryService.UpdateMinistryAsync(updatedMinistry);
            Snackbar.Add("Ministry updated successfully", Severity.Success);
            await LoadMinistries();
        }
    }

    private async Task Delete(Ministry ministry)
    {
        bool? result = await DialogService.ShowMessageBox(
        "Warning",
        $"Deleting {ministry.Name} cannot be undone!",
        yesText: "Delete!", cancelText: "Cancel");

        if (result == true)
        {
            await MinistryService.DeleteMinistryAsync(ministry.Id);
            Snackbar.Add("Ministry deleted", Severity.Success);
            await LoadMinistries();
        }
    }
}
